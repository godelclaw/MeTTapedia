    tttLargeFiber70ParentOfLow0Offset (i - 2720)
  else if 2784 <= i ∧ i < 2848 then
    tttLargeFiber70ParentOfLow1Offset (i - 2784)
  else if 2848 <= i ∧ i < 2912 then
    tttLargeFiber70ParentOfLow2Offset (i - 2848)
  else if 2912 <= i ∧ i < 2976 then
