def tttLargeFiber8ParentOf (i : Nat) : Nat :=
  if 4368 <= i ∧ i < 4432 then
    tttLargeFiber8ParentOfLow0Offset (i - 4368)
  else if 4432 <= i ∧ i < 4496 then
    tttLargeFiber8ParentOfLow1Offset (i - 4432)
  else if 4496 <= i ∧ i < 4560 then
    tttLargeFiber8ParentOfLow2Offset (i - 4496)
  else if 4560 <= i ∧ i < 4624 then
    tttLargeFiber8ParentOfLow3Offset (i - 4560)
  else if 6000 <= i ∧ i < 6064 then
    tttLargeFiber8ParentOfHigh0Offset (i - 6000)
  else if 6064 <= i ∧ i < 6128 then
    tttLargeFiber8ParentOfHigh1Offset (i - 6064)
  else if 6128 <= i ∧ i < 6192 then
    tttLargeFiber8ParentOfHigh2Offset (i - 6128)
  else if 6192 <= i ∧ i < 6256 then
    tttLargeFiber8ParentOfHigh3Offset (i - 6192)
  else
    i
def tttLargeFiber8ParentIter : Nat -> Nat -> Nat
  | 0, i => i
  | n + 1, i => tttLargeFiber8ParentIter n (tttLargeFiber8ParentOf i)

def tttLargeFiber8ParentConvergesCheck (i : Nat) : Bool :=
  tttLargeFiber8ParentIter tttLargeFiber8MaxParentDepth
    (listGetD tttLargeFiber8Expected i 0) == tttLargeFiber8Root

