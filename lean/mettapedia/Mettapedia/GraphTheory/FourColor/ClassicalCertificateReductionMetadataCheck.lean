private theorem blockBoolean_of_four_localBlockBooleans
    (certificate : ClassicalCertificateReductionMetadataCatalogue.Certificate)
    (chunkIndex : Nat) (chunk : Array Code)
    (hchunk : certificate.chunks[chunkIndex]? = some chunk)
    (h0 : localBlockBoolean chunk 0 = true)
    (h1 : localBlockBoolean chunk 1 = true)
    (h2 : localBlockBoolean chunk 2 = true)
    (h3 : localBlockBoolean chunk 3 = true)
    (subblock : Nat) (hsubblock : subblock < 4) :
    ClassicalCertificateReductionMetadataCatalogue.Certificate.blockBoolean
      certificate (chunkIndex * 4 + subblock) = true := by
  interval_cases subblock
  · exact blockBoolean_of_localBlockBoolean certificate chunkIndex chunk
      hchunk 0 (by decide) h0
  · exact blockBoolean_of_localBlockBoolean certificate chunkIndex chunk
      hchunk 1 (by decide) h1
  · exact blockBoolean_of_localBlockBoolean certificate chunkIndex chunk
      hchunk 2 (by decide) h2
  · exact blockBoolean_of_localBlockBoolean certificate chunkIndex chunk
      hchunk 3 (by decide) h3

private theorem classicalReductionMetadataBlocks000To015_checker
    (block : Nat) (hlower : 0 ≤ block)
    (hupper : block < 16) :
    ClassicalCertificateReductionMetadataCatalogue.Certificate.blockBoolean
      classicalReductionMetadataCatalogue block = true := by
  let chunkIndex := block / 4
  let subblock := block % 4
  have hsubblock : subblock < 4 :=
    Nat.mod_lt _ (by decide)
  have hdecomp : chunkIndex * 4 + subblock = block := by
    simpa [chunkIndex, subblock, Nat.mul_comm] using
      Nat.div_add_mod block 4
  rw [← hdecomp]
  have hchunkLower : 0 ≤ chunkIndex := by
    dsimp [chunkIndex]
    omega
  have hchunkUpper : chunkIndex < 4 := by
    dsimp [chunkIndex]
    omega
  interval_cases chunkIndex <;>
    first
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue 0
          classicalReductionMetadataChunk00 (by rfl)
            classicalReductionMetadataBlock000_checker
            classicalReductionMetadataBlock001_checker
            classicalReductionMetadataBlock002_checker
            classicalReductionMetadataBlock003_checker
            subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue 1
          classicalReductionMetadataChunk01 (by rfl)
            classicalReductionMetadataBlock004_checker
            classicalReductionMetadataBlock005_checker
            classicalReductionMetadataBlock006_checker
            classicalReductionMetadataBlock007_checker
            subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue 2
          classicalReductionMetadataChunk02 (by rfl)
            classicalReductionMetadataBlock008_checker
            classicalReductionMetadataBlock009_checker
            classicalReductionMetadataBlock010_checker
            classicalReductionMetadataBlock011_checker
            subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue 3
          classicalReductionMetadataChunk03 (by rfl)
            classicalReductionMetadataBlock012_checker
            classicalReductionMetadataBlock013_checker
            classicalReductionMetadataBlock014_checker
            classicalReductionMetadataBlock015_checker
            subblock hsubblock

