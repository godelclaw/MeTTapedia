/-- All 633 reduction records pass the local semantic checker. -/
theorem classicalReductionMetadata_checker :
    ClassicalCertificateReductionMetadataCatalogue.Certificate.checker
      classicalReductionMetadataCatalogue = true := by
  unfold ClassicalCertificateReductionMetadataCatalogue.Certificate.checker
    ClassicalCertificateReductionMetadataCatalogue.Certificate.blockCount
  rw [classicalReductionMetadataCatalogue_chunkCount]
  norm_num [ClassicalCertificateReductionMetadataCatalogue.Certificate.blocksPerChunk,
    ClassicalCertificateReductionMetadataCatalogue.Certificate.chunkSize,
    ClassicalCertificateReductionMetadataCatalogue.Certificate.blockSize]
  intro block hblock
  by_cases h0 : block < 16
  · exact classicalReductionMetadataBlocks000To015_checker block (by omega) h0
  by_cases h1 : block < 32
  · exact classicalReductionMetadataBlocks016To031_checker block (by omega) h1
  by_cases h2 : block < 48
  · exact classicalReductionMetadataBlocks032To047_checker block (by omega) h2
  by_cases h3 : block < 64
  · exact classicalReductionMetadataBlocks048To063_checker block (by omega) h3
  by_cases h4 : block < 80
  · exact classicalReductionMetadataBlocks064To079_checker block (by omega) h4
  by_cases h5 : block < 96
  · exact classicalReductionMetadataBlocks080To095_checker block (by omega) h5
  by_cases h6 : block < 112
  · exact classicalReductionMetadataBlocks096To111_checker block (by omega) h6
  by_cases h7 : block < 128
  · exact classicalReductionMetadataBlocks112To127_checker block (by omega) h7
  by_cases h8 : block < 144
  · exact classicalReductionMetadataBlocks128To143_checker block (by omega) h8
  exact classicalReductionMetadataBlocks144To159_checker block (by omega) hblock

/-- Every classical catalogue index selects semantically valid reduction
metadata. -/
theorem exists_valid_classicalReductionMetadata
    (index : Nat) (hindex : index < 633) :
    ∃ code,
      ClassicalCertificateReductionMetadataCatalogue.Certificate.codeAt?
          classicalReductionMetadataCatalogue index = some code ∧
        ClassicalCertificateReductionMetadata.Valid code := by
  obtain ⟨code, hcode⟩ :=
    ClassicalCertificateReductionMetadataCatalogue.Certificate.exists_code_of_populatedPrefixBoolean
      classicalReductionMetadataCatalogue 633
        classicalReductionMetadataCatalogue_populated index hindex
  refine ⟨code, hcode, ?_⟩
  apply ClassicalCertificateReductionMetadataCatalogue.Certificate.valid_of_checker_true
    classicalReductionMetadataCatalogue classicalReductionMetadata_checker index
  · simp only [
      ClassicalCertificateReductionMetadataCatalogue.Certificate.valueBound,
      classicalReductionMetadataCatalogue_chunkCount,
      ClassicalCertificateReductionMetadataCatalogue.Certificate.chunkSize]
    omega
  · exact hcode

end ClassicalCertificateReductionMetadataCheck

