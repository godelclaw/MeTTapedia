    tttLargeFiber30ParentOfLow0Offset (i - 0)
  else if 64 <= i ∧ i < 128 then
    tttLargeFiber30ParentOfLow1Offset (i - 64)
  else if 128 <= i ∧ i < 192 then
    tttLargeFiber30ParentOfLow2Offset (i - 128)
  else if 192 <= i ∧ i < 256 then
    tttLargeFiber30ParentOfLow3Offset (i - 192)
  else if 1632 <= i ∧ i < 1696 then
    tttLargeFiber30ParentOfHigh0Offset (i - 1632)
  else if 1696 <= i ∧ i < 1760 then
    tttLargeFiber30ParentOfHigh1Offset (i - 1696)
  else if 1760 <= i ∧ i < 1824 then
    tttLargeFiber30ParentOfHigh2Offset (i - 1760)
  else if 1824 <= i ∧ i < 1888 then
    tttLargeFiber30ParentOfHigh3Offset (i - 1824)
  else
    i
