def tttLargeFiber36ParentOf (i : Nat) : Nat :=
  if 272 <= i ∧ i < 336 then
    tttLargeFiber36ParentOfLow0Offset (i - 272)
  else if 336 <= i ∧ i < 400 then
    tttLargeFiber36ParentOfLow1Offset (i - 336)
  else if 400 <= i ∧ i < 464 then
    tttLargeFiber36ParentOfLow2Offset (i - 400)
  else if 464 <= i ∧ i < 528 then
    tttLargeFiber36ParentOfLow3Offset (i - 464)
  else if 1904 <= i ∧ i < 1968 then
    tttLargeFiber36ParentOfHigh0Offset (i - 1904)
  else if 1968 <= i ∧ i < 2032 then
    tttLargeFiber36ParentOfHigh1Offset (i - 1968)
  else if 2032 <= i ∧ i < 2096 then
    tttLargeFiber36ParentOfHigh2Offset (i - 2032)
  else if 2096 <= i ∧ i < 2160 then
    tttLargeFiber36ParentOfHigh3Offset (i - 2096)
  else
    i
def tttLargeFiber36ParentIter : Nat -> Nat -> Nat
