/-- Every local backward edge in the first nonbase product layer is valid. -/
theorem twentiethCatalogueOrbitProductDagLayerOne_checker :
    checker twentiethCatalogueOrbitProductCertificate
      twentiethCatalogueOrbitProductDagLayerOne = true := by
  unfold checker
  rw [twentiethCatalogueOrbitProductDagLayerOneBlockCount]
  apply List.all_eq_true.2
  intro block hblock
  exact twentiethCatalogueOrbitProductDagLayerOneBlock_checker block
    (List.mem_range.1 hblock)

def twentiethCatalogueOrbitProductDagLayerOneRootNode : NodeCode :=
  ⟨⟨1, 12, 1566, some 30471, []⟩, [10128, 56667, 56668]⟩

theorem twentiethCatalogueOrbitProductDagLayerOneRoot_isNode :
    twentiethCatalogueOrbitProductDagLayerOne.nodeAt? 56669 =
      some twentiethCatalogueOrbitProductDagLayerOneRootNode := by
  rfl

/-- The complete first orbit layer is covered by strictly lower response
leaves in the shared chromogram dictionary. -/
theorem twentiethCatalogueOrbitProductLayerOne_checker :
    ClassicalCertificateTraceResponseProduct.layerBoolean
      twentiethCatalogueOrbitProductCertificate 1 = true := by
  have hevaluate := evaluate_eq_true_of_checker_true
    twentiethCatalogueOrbitProductCertificate
      twentiethCatalogueOrbitProductDagLayerOne
        twentiethCatalogueOrbitProductDagLayerOne_checker 56669 (by decide)
          twentiethCatalogueOrbitProductDagLayerOneRootNode
            twentiethCatalogueOrbitProductDagLayerOneRoot_isNode
  change productBoolean twentiethCatalogueOrbitProductCertificate
    1 12 1566 (some 30471) [] = true
  simpa [evaluate, twentiethCatalogueOrbitProductDagLayerOneRootNode] using
    hevaluate

