theorem mmFiber51ExtractAllLefts_eq_nil :
    lengthTwoFiberExtractLeftStateList mmWord mmFiber51Key allTauStates = [] := by
  rw [allTauStates_eq_chunks32]
  repeat rw [lengthTwoFiberExtractLeftStateList_append]
  decide

theorem mmFiber51RealFiberConnected :
    chainFiberConnected mmWord (chainFiberFrom mmWord (allChainStates mmWord) mmFiber51Key) = true := by
  exact mmEmptyFiberConnected_of_extract_nil mmFiber51ExtractAllLefts_eq_nil

