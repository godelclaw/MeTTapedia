def tttLargeFiber20ParentOf (i : Nat) : Nat :=
  if 4640 <= i ∧ i < 4704 then
    tttLargeFiber20ParentOfLow0Offset (i - 4640)
  else if 4704 <= i ∧ i < 4768 then
    tttLargeFiber20ParentOfLow1Offset (i - 4704)
  else if 4768 <= i ∧ i < 4832 then
    tttLargeFiber20ParentOfLow2Offset (i - 4768)
  else if 4832 <= i ∧ i < 4896 then
    tttLargeFiber20ParentOfLow3Offset (i - 4832)
  else if 6272 <= i ∧ i < 6336 then
    tttLargeFiber20ParentOfHigh0Offset (i - 6272)
  else if 6336 <= i ∧ i < 6400 then
    tttLargeFiber20ParentOfHigh1Offset (i - 6336)
  else if 6400 <= i ∧ i < 6464 then
    tttLargeFiber20ParentOfHigh2Offset (i - 6400)
  else if 6464 <= i ∧ i < 6528 then
    tttLargeFiber20ParentOfHigh3Offset (i - 6464)
  else
    i
def tttLargeFiber20ParentIter : Nat -> Nat -> Nat
  | 0, i => i
