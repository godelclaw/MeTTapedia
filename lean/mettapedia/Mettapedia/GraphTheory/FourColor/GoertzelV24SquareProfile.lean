import Mettapedia.GraphTheory.FourColor.GoertzelV24SquareKempe

namespace Mettapedia.GraphTheory.FourColor

open SimpleGraph

set_option maxRecDepth 100000
set_option maxHeartbeats 4000000

/-- Membership in the pair of colors whose connectivity profile is being
tracked. -/
def IsTrackedColor (a b c : Color) : Prop := c = a ∨ c = b
  deriving Decidable

/-- Four portal nodes followed by the four square-corner nodes. -/
abbrev SquareLocalNode := Fin 8

def squarePortalNode (i : Fin 4) : SquareLocalNode :=
  ⟨i.val, by omega⟩

def squareCornerNode (i : Fin 4) : SquareLocalNode :=
  ⟨i.val + 4, by omega⟩

/-- The symmetric relation generated by one unordered pair. -/
def SquareUndirectedEdge (u v p q : SquareLocalNode) : Prop :=
  (u = p ∧ v = q) ∨ (u = q ∧ v = p)
  deriving Decidable

/-- The tracked-color subgraph of a locally colored square, including the
four boundary portals and their four outer half-edges. -/
def SquareLocalAdjProp (w : SquareBoundaryWord) (x : SquareInternalColoring)
    (a b : Color) (u v : SquareLocalNode) : Prop :=
  (SquareUndirectedEdge u v (squarePortalNode 0) (squareCornerNode 0) ∧
    IsTrackedColor a b (w 0)) ∨
  (SquareUndirectedEdge u v (squarePortalNode 1) (squareCornerNode 1) ∧
    IsTrackedColor a b (w 1)) ∨
  (SquareUndirectedEdge u v (squarePortalNode 2) (squareCornerNode 2) ∧
    IsTrackedColor a b (w 2)) ∨
  (SquareUndirectedEdge u v (squarePortalNode 3) (squareCornerNode 3) ∧
    IsTrackedColor a b (w 3)) ∨
  (SquareUndirectedEdge u v (squareCornerNode 0) (squareCornerNode 1) ∧
    IsTrackedColor a b (x 0)) ∨
  (SquareUndirectedEdge u v (squareCornerNode 1) (squareCornerNode 2) ∧
    IsTrackedColor a b (x 1)) ∨
  (SquareUndirectedEdge u v (squareCornerNode 2) (squareCornerNode 3) ∧
    IsTrackedColor a b (x 2)) ∨
  (SquareUndirectedEdge u v (squareCornerNode 3) (squareCornerNode 0) ∧
    IsTrackedColor a b (x 3))
  deriving Decidable

def SquareLocalAdj (w : SquareBoundaryWord) (x : SquareInternalColoring)
    (a b : Color) (u v : SquareLocalNode) : Bool :=
  decide (SquareLocalAdjProp w x a b u v)

/-- One monotone breadth-first expansion of a finite set. -/
def finsetReachStep {N : Type*} [Fintype N] [DecidableEq N]
    (adj : N → N → Bool) (seen : Finset N) : Finset N :=
  seen ∪ Finset.univ.filter fun v => Finset.sup seen (fun u => adj u v) = true

/-- Nodes reached by at most `steps` breadth-first expansions. -/
def finsetReachWithin {N : Type*} [Fintype N] [DecidableEq N]
    (adj : N → N → Bool) (source : N) (steps : Nat) : Finset N :=
  Nat.iterate (finsetReachStep adj) steps {source}

theorem finset_sup_bool_eq_true_iff_exists {N : Type*} [DecidableEq N]
    (s : Finset N) (f : N → Bool) :
    Finset.sup s f = true ↔ ∃ x ∈ s, f x = true := by
  induction s using Finset.induction with
  | empty => simp
  | @insert a s ha ih =>
      simp [Finset.sup_insert, ih, Bool.or_eq_true]

theorem mem_finsetReachStep_iff {N : Type*} [Fintype N] [DecidableEq N]
    (adj : N → N → Bool) (seen : Finset N) (v : N) :
    v ∈ finsetReachStep adj seen ↔
      v ∈ seen ∨ ∃ u ∈ seen, adj u v = true := by
  simp [finsetReachStep, finset_sup_bool_eq_true_iff_exists]

/-- Breadth-first membership is exactly existence of a graph walk within the
iteration bound. -/
theorem mem_finsetReachWithin_iff_exists_walk_length_le
    {N : Type*} [Fintype N] [DecidableEq N]
    (G : SimpleGraph N) (adj : N → N → Bool)
    (hadj : ∀ u v, adj u v = true ↔ G.Adj u v)
    (source v : N) (n : Nat) :
    v ∈ finsetReachWithin adj source n ↔
      ∃ p : G.Walk source v, p.length ≤ n := by
  induction n generalizing v with
  | zero =>
      constructor
      · intro hv
        have hvs : v = source := by
          simpa [finsetReachWithin] using hv
        subst v
        exact ⟨Walk.nil, by simp⟩
      · rintro ⟨p, hp⟩
        have hlen : p.length = 0 := by omega
        have hsv : source = v := Walk.eq_of_length_eq_zero hlen
        subst v
        simp [finsetReachWithin]
  | succ n ih =>
      rw [show finsetReachWithin adj source (n + 1) =
          finsetReachStep adj (finsetReachWithin adj source n) by
        simp [finsetReachWithin, Function.iterate_succ_apply']]
      rw [mem_finsetReachStep_iff]
      constructor
      · intro hv
        rcases hv with hv | ⟨u, hu, huv⟩
        · rcases (ih v).mp hv with ⟨p, hp⟩
          exact ⟨p, by omega⟩
        · rcases (ih u).mp hu with ⟨p, hp⟩
          exact ⟨p.concat ((hadj u v).mp huv), by simp; omega⟩
      · rintro ⟨p, hp⟩
        by_cases hnil : p.Nil
        · have hsv : source = v := Walk.Nil.eq hnil
          subst v
          exact Or.inl (by
            apply (ih source).mpr
            exact ⟨Walk.nil, by simp⟩)
        · apply Or.inr
          refine ⟨p.penultimate, (ih p.penultimate).mpr ⟨p.dropLast, ?_⟩, ?_⟩
          · have hlen := p.length_dropLast_add_one hnil
            omega
          · exact (hadj p.penultimate v).mpr (p.adj_penultimate hnil)

/-- On a finite graph, `card N` breadth-first expansions decide ordinary
`SimpleGraph.Reachable`. -/
theorem mem_finsetReachWithin_card_iff_reachable
    {N : Type*} [Fintype N] [DecidableEq N]
    (G : SimpleGraph N) (adj : N → N → Bool)
    (hadj : ∀ u v, adj u v = true ↔ G.Adj u v)
    (source v : N) :
    v ∈ finsetReachWithin adj source (Fintype.card N) ↔
      G.Reachable source v := by
  constructor
  · intro hv
    rcases (mem_finsetReachWithin_iff_exists_walk_length_le
      G adj hadj source v (Fintype.card N)).mp hv with ⟨p, _hp⟩
    exact p.reachable
  · intro hv
    rcases hv.exists_isPath with ⟨p, hp⟩
    apply (mem_finsetReachWithin_iff_exists_walk_length_le
      G adj hadj source v (Fintype.card N)).mpr
    exact ⟨p, Nat.le_of_lt hp.length_lt⟩

theorem squareLocalAdj_symm (w : SquareBoundaryWord)
    (x : SquareInternalColoring) (a b : Color) (u v : SquareLocalNode) :
    SquareLocalAdj w x a b u v = SquareLocalAdj w x a b v u := by
  apply Bool.decide_congr
  unfold SquareLocalAdjProp SquareUndirectedEdge
  aesop

theorem squareLocalAdj_self (w : SquareBoundaryWord)
    (x : SquareInternalColoring) (a b : Color) (u : SquareLocalNode) :
    SquareLocalAdj w x a b u u = false := by
  simp only [SquareLocalAdj, decide_eq_false_iff_not]
  fin_cases u <;>
    simp [SquareLocalAdjProp, SquareUndirectedEdge,
      squarePortalNode, squareCornerNode]

/-- Portal-to-portal connectivity for one tracked color pair. -/
abbrev SquareTrackedProfile := Fin 4 → Fin 4 → Bool

def squareTrackedProfile (w : SquareBoundaryWord)
    (x : SquareInternalColoring) (a b : Color) : SquareTrackedProfile :=
  fun i j =>
    decide (IsTrackedColor a b (w i)) &&
    decide (IsTrackedColor a b (w j)) &&
    decide (squarePortalNode j ∈
      finsetReachWithin (SquareLocalAdj w x a b) (squarePortalNode i) 8)

def squareLocalGraph (w : SquareBoundaryWord) (x : SquareInternalColoring)
    (a b : Color) : SimpleGraph SquareLocalNode where
  Adj u v := SquareLocalAdj w x a b u v = true
  symm := ⟨by
    intro u v huv
    rw [squareLocalAdj_symm w x a b u v] at huv
    exact huv⟩
  loopless := ⟨by
    intro u huu
    rw [squareLocalAdj_self w x a b u] at huu
    contradiction⟩

/-- The computed square profile is the ordinary reachability relation on
the tracked-color local graph. -/
theorem squareTrackedProfile_eq_true_iff
    (w : SquareBoundaryWord) (x : SquareInternalColoring)
    (a b : Color) (i j : Fin 4) :
    squareTrackedProfile w x a b i j = true ↔
      IsTrackedColor a b (w i) ∧ IsTrackedColor a b (w j) ∧
      (squareLocalGraph w x a b).Reachable
        (squarePortalNode i) (squarePortalNode j) := by
  unfold squareTrackedProfile
  simp only [Bool.and_eq_true, decide_eq_true_eq]
  have hreach :
      squarePortalNode j ∈
          finsetReachWithin (SquareLocalAdj w x a b) (squarePortalNode i) 8 ↔
        (squareLocalGraph w x a b).Reachable
          (squarePortalNode i) (squarePortalNode j) := by
    simpa using mem_finsetReachWithin_card_iff_reachable
      (squareLocalGraph w x a b) (SquareLocalAdj w x a b)
      (by intros; rfl) (squarePortalNode i) (squarePortalNode j)
  rw [hreach]
  tauto

/-- The two planar pairings obtained by deleting a square. The `Fin 2`
encoding keeps the complete profile audit kernel-reducible. -/
abbrev SquareReductionSide := Fin 2

def SquareReductionSide.join01_23 : SquareReductionSide := 0

def SquareReductionSide.join12_30 : SquareReductionSide := 1

/-- Boundary equality needed for the selected planar pairing to preserve
the coloring. -/
def SquareReductionSide.Compatible
    (side : SquareReductionSide) (w : SquareBoundaryWord) : Prop :=
  if side = .join01_23 then w 0 = w 1 ∧ w 2 = w 3
  else w 1 = w 2 ∧ w 3 = w 0
  deriving Decidable

def SquareReductionSide.Adj
    (side : SquareReductionSide) (w : SquareBoundaryWord) (a b : Color)
    (i j : Fin 4) : Bool :=
  decide (IsTrackedColor a b (w i)) &&
  decide (IsTrackedColor a b (w j)) &&
  if side = .join01_23 then
    decide ((i = 0 ∧ j = 1) ∨ (i = 1 ∧ j = 0) ∨
      (i = 2 ∧ j = 3) ∨ (i = 3 ∧ j = 2))
  else
    decide ((i = 1 ∧ j = 2) ∨ (i = 2 ∧ j = 1) ∨
      (i = 3 ∧ j = 0) ∨ (i = 0 ∧ j = 3))

theorem SquareReductionSide.adj_symm (side : SquareReductionSide)
    (w : SquareBoundaryWord) (a b : Color) (i j : Fin 4) :
    side.Adj w a b i j = side.Adj w a b j i := by
  fin_cases side <;> fin_cases i <;> fin_cases j <;>
    simp [SquareReductionSide.Adj, Bool.and_comm]

theorem SquareReductionSide.adj_self (side : SquareReductionSide)
    (w : SquareBoundaryWord) (a b : Color) (i : Fin 4) :
    side.Adj w a b i i = false := by
  fin_cases side <;> fin_cases i <;>
    simp [SquareReductionSide.Adj]

def squareReductionGraph (side : SquareReductionSide)
    (w : SquareBoundaryWord) (a b : Color) : SimpleGraph (Fin 4) where
  Adj i j := side.Adj w a b i j = true
  symm := ⟨by
    intro i j hij
    rw [side.adj_symm w a b i j] at hij
    exact hij⟩
  loopless := ⟨by
    intro i hii
    rw [side.adj_self w a b i] at hii
    contradiction⟩

def squareReductionTrackedProfile (side : SquareReductionSide)
    (w : SquareBoundaryWord) (a b : Color) : SquareTrackedProfile :=
  fun i j =>
    decide (IsTrackedColor a b (w i)) &&
    decide (IsTrackedColor a b (w j)) &&
    decide (j ∈ finsetReachWithin (side.Adj w a b) i 4)

/-- A computed planar-pairing profile is ordinary reachability on its
four-portal reduction graph. -/
theorem squareReductionTrackedProfile_eq_true_iff
    (side : SquareReductionSide) (w : SquareBoundaryWord)
    (a b : Color) (i j : Fin 4) :
    squareReductionTrackedProfile side w a b i j = true ↔
      IsTrackedColor a b (w i) ∧ IsTrackedColor a b (w j) ∧
      (squareReductionGraph side w a b).Reachable i j := by
  unfold squareReductionTrackedProfile
  simp only [Bool.and_eq_true, decide_eq_true_eq]
  have hreach :
      j ∈ finsetReachWithin (side.Adj w a b) i 4 ↔
        (squareReductionGraph side w a b).Reachable i j := by
    simpa using mem_finsetReachWithin_card_iff_reachable
      (squareReductionGraph side w a b) (side.Adj w a b)
      (by intros; rfl) i j
  rw [hreach]
  tauto

/-- Connectivity profiles of every proper local square extension. -/
def squareExtensionProfileMultiset
    (w : SquareBoundaryWord) (a b : Color) : Multiset SquareTrackedProfile :=
  (squareExtensions w).val.map fun x => squareTrackedProfile w x a b

/-- Connectivity profiles of the compatible planar square reductions. -/
def squareReductionProfileMultiset
    (w : SquareBoundaryWord) (a b : Color) : Multiset SquareTrackedProfile :=
  (Finset.univ.filter fun side : SquareReductionSide => side.Compatible w).val.map
    fun side => squareReductionTrackedProfile side w a b

private theorem squareLocalProfileIdentity_check :
    ∀ w : SquareBoundaryWord, ∀ a b : Color,
      ¬ SquareBoundaryWord.Nonzero w ∨ a = 0 ∨ b = 0 ∨ a = b ∨
      squareExtensionProfileMultiset w a b =
        squareReductionProfileMultiset w a b := by
  decide

/-- The local profile identity underlying the square reduction: for every
nonzero square boundary word and every genuine tracked color pair, the
multiset of portal-connectivity profiles of all proper square extensions is
exactly the multiset from the two compatible planar pairings.

This is the complete finite local kernel of SQ2. The ambient counting
identity additionally requires a compositional theorem showing that equal
portal relations remain interchangeable after gluing an arbitrary exterior. -/
theorem squareLocalProfileIdentity :
    ∀ w : SquareBoundaryWord, ∀ a b : Color,
      SquareBoundaryWord.Nonzero w → a ≠ 0 → b ≠ 0 → a ≠ b →
      squareExtensionProfileMultiset w a b =
        squareReductionProfileMultiset w a b := by
  intro w a b hw ha hb hab
  rcases squareLocalProfileIdentity_check w a b with hn | ha0 | hb0 | hab0 | h
  · exact False.elim (hn hw)
  · exact False.elim (ha ha0)
  · exact False.elim (hb hb0)
  · exact False.elim (hab hab0)
  · exact h

end Mettapedia.GraphTheory.FourColor
