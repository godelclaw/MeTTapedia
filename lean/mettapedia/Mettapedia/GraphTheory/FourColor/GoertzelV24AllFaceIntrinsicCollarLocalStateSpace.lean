namespace IntrinsicShortTargetEscapeCollar

/-- Ordered pairs of distinct nonzero colors generating the canonical
`01|23` own-boundary words. -/
noncomputable def canonicalOwnColorPairs : Finset (Color × Color) :=
  Finset.univ.filter fun colors =>
    colors.1 ≠ 0 ∧ colors.2 ≠ 0 ∧ colors.1 ≠ colors.2

/-- The canonical `01|23` word generated by two ordered colors. -/
def canonicalOwnBoundaryWord (colors : Color × Color) :
    SquareBoundaryWord :=
  fun port => if port = 0 ∨ port = 1 then colors.1 else colors.2

/-- The canonical-word generator remembers both ordered colors. -/
theorem canonicalOwnBoundaryWord_injective :
    Function.Injective canonicalOwnBoundaryWord := by
  intro first second hword
  apply Prod.ext
  · have hzero := congrFun hword 0
    simpa [canonicalOwnBoundaryWord] using hzero
  · have htwo := congrFun hword 2
    simpa [canonicalOwnBoundaryWord] using htwo

/-- The six nonzero canonical `01|23` boundary words. -/
noncomputable def canonicalOwnBoundaryWords : Finset SquareBoundaryWord :=
  canonicalOwnColorPairs.image canonicalOwnBoundaryWord

/-- A bridge color together with one chosen first color on each side. -/
abbrev BridgeExtensionSeed := Color × Color × Color

/-- The twelve seeds: a nonzero bridge and, independently on each side, a
nonzero first color different from the bridge. -/
noncomputable def bridgeExtensionSeeds : Finset BridgeExtensionSeed :=
  Finset.univ.filter fun seed =>
    seed.1 ≠ 0 ∧ seed.2.1 ≠ 0 ∧ seed.2.1 ≠ seed.1 ∧
      seed.2.2 ≠ 0 ∧ seed.2.2 ≠ seed.1

/-- The cross word generated by a bridge-extension seed. -/
def bridgeExtensionWordOfSeed (seed : BridgeExtensionSeed) :
    SquareBoundaryWord :=
  fun port =>
    if port = 0 then seed.2.1
    else if port = 1 then seed.2.1 + seed.1
    else if port = 2 then seed.2.2
    else seed.2.2 + seed.1

/-- The cross word together with the bridge retained in its seed. -/
def bridgeExtensionWordColorOfSeed (seed : BridgeExtensionSeed) :
    SquareBoundaryWord × Color :=
  (bridgeExtensionWordOfSeed seed, seed.1)

/-- The bridge-extension generator remembers its bridge and both first
side colors. -/
theorem bridgeExtensionWordColorOfSeed_injective :
    Function.Injective bridgeExtensionWordColorOfSeed := by
  intro first second hdata
  have hbridge : first.1 = second.1 := congrArg Prod.snd hdata
  have hword : bridgeExtensionWordOfSeed first =
      bridgeExtensionWordOfSeed second := congrArg Prod.fst hdata
  have hfirst : first.2.1 = second.2.1 := by
    have hzero := congrFun hword 0
    simpa [bridgeExtensionWordOfSeed] using hzero
  have hsecond : first.2.2 = second.2.2 := by
    have htwo := congrFun hword 2
    simpa [bridgeExtensionWordOfSeed] using htwo
  exact Prod.ext hbridge (Prod.ext hfirst hsecond)

/-- The twelve cross-boundary-word and bridge-color pairs that restore an
adjacent cubic vertex pair. -/
noncomputable def bridgeExtensionWordColors :
    Finset (SquareBoundaryWord × Color) :=
  bridgeExtensionSeeds.image bridgeExtensionWordColorOfSeed

/-- The generator description is exactly the nonzero canonical own-word
class. -/
@[simp]
theorem mem_canonicalOwnBoundaryWords_iff
    (word : SquareBoundaryWord) :
    word ∈ canonicalOwnBoundaryWords ↔
      word.Nonzero ∧ word.Adjacent01_23 := by
  decide +revert

/-- The bridge generators are exactly the locally extendable cross words
together with their bridge colors. -/
@[simp]
theorem mem_bridgeExtensionWordColors_iff
    (word : SquareBoundaryWord) (bridge : Color) :
    (word, bridge) ∈ bridgeExtensionWordColors ↔
      IsTwoVertexBridgeExtension word bridge := by
  decide +revert

/-- All five-symbol correction halves allowed by the local completion
matrix, after forgetting which matrix entries generated the word. -/
noncomputable def locallyRealizableCorrectionHalfWords :
    Finset IntrinsicCollarCorrectionHalfWord :=
  (canonicalOwnBoundaryWords ×ˢ bridgeExtensionWordColors).image
    fun data => localCorrectionHalfWord data.1 data.2.1 data.2.2

/-- All ten-symbol correction words obtained by independently joining two
locally realizable halves. -/
noncomputable def locallyRealizableCorrectionWords :
    Finset IntrinsicCollarCorrectionWord :=
  (locallyRealizableCorrectionHalfWords ×ˢ
      locallyRealizableCorrectionHalfWords).image
    fun data => correctionWordOfHalfWords data.1 data.2

/-- Any local completion matrix satisfying the own-word and bridge
conditions generates one of the thirty-six half words. -/
theorem localCorrectionHalfWord_mem
    (own cross : SquareBoundaryWord) (bridge : Color)
    (hownNonzero : own.Nonzero)
    (hownClass : own.Adjacent01_23)
    (hextension : IsTwoVertexBridgeExtension cross bridge) :
    localCorrectionHalfWord own cross bridge ∈
      locallyRealizableCorrectionHalfWords := by
  rw [locallyRealizableCorrectionHalfWords, Finset.mem_image]
  exact ⟨(own, (cross, bridge)),
    Finset.mem_product.mpr
      ⟨mem_canonicalOwnBoundaryWords_iff own |>.2
          ⟨hownNonzero, hownClass⟩,
        mem_bridgeExtensionWordColors_iff cross bridge |>.2 hextension⟩,
    rfl⟩

/-- Joining any two locally realizable halves produces one of the 1296
full local correction words. -/
theorem correctionWordOfHalfWords_mem
    (source target : IntrinsicCollarCorrectionHalfWord)
    (hsource : source ∈ locallyRealizableCorrectionHalfWords)
    (htarget : target ∈ locallyRealizableCorrectionHalfWords) :
    correctionWordOfHalfWords source target ∈
      locallyRealizableCorrectionWords := by
  rw [locallyRealizableCorrectionWords, Finset.mem_image]
  exact ⟨(source, target), Finset.mem_product.mpr ⟨hsource, htarget⟩, rfl⟩

/-- The four-port word of any recovered adjacent-pair deletion is nonzero
under the ambient cubic hypothesis. -/
theorem degreeTwoBoundaryColorWord_nonzero
    (data : AdjacentPairData G)
    (hcubic : ∀ vertex : V, (incidentEdgeFinset G vertex).card = 3)
    (coloring : (DeletedAdjacentPairGraph G data.firstVertex
      data.secondVertex).EdgeColoring Color) :
    SquareBoundaryWord.Nonzero
      (data.degreeTwoBoundaryData.colorWord coloring) := by
  have hwell := data.degreeTwoBoundaryData_wellFormed hcubic
  exact ⟨
    data.degreeTwoBoundaryData.colorWord_ne_zero hwell coloring 0,
    data.degreeTwoBoundaryData.colorWord_ne_zero hwell coloring 1,
    data.degreeTwoBoundaryData.colorWord_ne_zero hwell coloring 2,
    data.degreeTwoBoundaryData.colorWord_ne_zero hwell coloring 3⟩

/-- The source escape's own canonical boundary word is nonzero. -/
theorem sourceOwnBoundaryWord_nonzero
    {cycle :
      CrossCentralExactFaceCertifiedRebaseCircuit.RemoteDualCycle
        rebaseCircuit}
    {targetEdge : G.edgeSet}
    {sourceNormal : RotationOrderedCyclicKempeFusionChainNormalForm
      graphData minimal baseData}
    (collar : cycle.IntrinsicShortTargetEscapeCollar targetEdge)
    (sourceEscape : sourceNormal.KempeOrbitAdjacentEscape) :
    SquareBoundaryWord.Nonzero
      (collar.sourceData.degreeTwoBoundaryData.colorWord
        sourceEscape.coloring) := by
  apply degreeTwoBoundaryColorWord_nonzero collar.sourceData
  exact incidentEdgeFinset_card_eq_three_of_toRotationSystem_isCubic
    graphData minimal.spherical.cubic

/-- The target escape's own canonical boundary word is nonzero. -/
theorem targetOwnBoundaryWord_nonzero
    {cycle :
      CrossCentralExactFaceCertifiedRebaseCircuit.RemoteDualCycle
        rebaseCircuit}
    {targetEdge : G.edgeSet}
    (collar : cycle.IntrinsicShortTargetEscapeCollar targetEdge) :
    SquareBoundaryWord.Nonzero
      (collar.targetData.degreeTwoBoundaryData.colorWord
        collar.targetEscape.coloring) := by
  apply degreeTwoBoundaryColorWord_nonzero collar.targetData
  exact incidentEdgeFinset_card_eq_three_of_toRotationSystem_isCubic
    graphData minimal.spherical.cubic

/-- Every actual source half lies in the thirty-six-state local set. -/
theorem sourceLocalCorrectionHalfWord_mem
    {cycle :
      CrossCentralExactFaceCertifiedRebaseCircuit.RemoteDualCycle
        rebaseCircuit}
    {targetEdge : G.edgeSet}
    {sourceNormal : RotationOrderedCyclicKempeFusionChainNormalForm
      graphData minimal baseData}
    (collar : cycle.IntrinsicShortTargetEscapeCollar targetEdge)
    (sourceEscape : sourceNormal.KempeOrbitAdjacentEscape) :
    collar.sourceLocalCorrectionHalfWord sourceEscape ∈
      locallyRealizableCorrectionHalfWords := by
  unfold sourceLocalCorrectionHalfWord
  exact localCorrectionHalfWord_mem _ _ _
    (collar.sourceOwnBoundaryWord_nonzero sourceEscape)
    sourceEscape.boundary_adjacent01_23 collar.sourceBridgeExtension

/-- Every actual target half lies in the same thirty-six-state local set. -/
theorem targetLocalCorrectionHalfWord_mem
    {cycle :
      CrossCentralExactFaceCertifiedRebaseCircuit.RemoteDualCycle
        rebaseCircuit}
    {targetEdge : G.edgeSet}
    {sourceNormal : RotationOrderedCyclicKempeFusionChainNormalForm
      graphData minimal baseData}
    (collar : cycle.IntrinsicShortTargetEscapeCollar targetEdge)
    (sourceEscape : sourceNormal.KempeOrbitAdjacentEscape) :
    collar.targetLocalCorrectionHalfWord sourceEscape ∈
      locallyRealizableCorrectionHalfWords := by
  unfold targetLocalCorrectionHalfWord
  exact localCorrectionHalfWord_mem _ _ _
    collar.targetOwnBoundaryWord_nonzero
    collar.targetEscape.boundary_adjacent01_23
    (collar.targetBridgeExtensionInSource sourceEscape)

/-- Every actual intrinsic completion correction belongs to the fixed
1296-state local completion-matrix space. -/
theorem intrinsicCollarCorrectionWord_mem_locallyRealizable
    {cycle :
      CrossCentralExactFaceCertifiedRebaseCircuit.RemoteDualCycle
        rebaseCircuit}
    {targetEdge : G.edgeSet}
    {sourceNormal : RotationOrderedCyclicKempeFusionChainNormalForm
      graphData minimal baseData}
    (collar : cycle.IntrinsicShortTargetEscapeCollar targetEdge)
    (sourceEscape : sourceNormal.KempeOrbitAdjacentEscape) :
    collar.intrinsicCollarCorrectionWord sourceEscape ∈
      locallyRealizableCorrectionWords := by
  rw [collar.intrinsicCollarCorrectionWord_eq_correctionWordOfHalfWords]
  exact correctionWordOfHalfWords_mem _ _
    (collar.sourceLocalCorrectionHalfWord_mem sourceEscape)
    (collar.targetLocalCorrectionHalfWord_mem sourceEscape)

/-- There are exactly six possible own canonical boundary words. -/
theorem card_canonicalOwnBoundaryWords :
    canonicalOwnBoundaryWords.card = 6 := by
  rw [canonicalOwnBoundaryWords,
    Finset.card_image_of_injective _ canonicalOwnBoundaryWord_injective]
  decide

/-- There are exactly twelve cross-word/bridge extension pairs. -/
theorem card_bridgeExtensionWordColors :
    bridgeExtensionWordColors.card = 12 := by
  rw [bridgeExtensionWordColors,
    Finset.card_image_of_injective _
      bridgeExtensionWordColorOfSeed_injective]
  decide

/-- Forgetting the generating matrix entries leaves exactly thirty-six
distinct five-symbol correction halves. -/
theorem card_locallyRealizableCorrectionHalfWords :
    locallyRealizableCorrectionHalfWords.card = 36 := by
  decide

/-- Joining two half words retains both halves and is injective. -/
theorem correctionWordOfHalfWords_pair_injective :
    Function.Injective
      (fun data : IntrinsicCollarCorrectionHalfWord ×
          IntrinsicCollarCorrectionHalfWord =>
        correctionWordOfHalfWords data.1 data.2) := by
  intro first second hword
  apply Prod.ext
  · funext coordinate
    exact congrFun hword (Sum.inl coordinate)
  · funext coordinate
    exact congrFun hword (Sum.inr coordinate)

/-- The graph-independent local completion-matrix filter contains exactly
`36^2 = 1296` ten-symbol correction words. -/
theorem card_locallyRealizableCorrectionWords :
    locallyRealizableCorrectionWords.card = 1296 := by
  rw [locallyRealizableCorrectionWords,
    Finset.card_image_of_injective _
      correctionWordOfHalfWords_pair_injective,
    Finset.card_product,
    card_locallyRealizableCorrectionHalfWords]

end IntrinsicShortTargetEscapeCollar

