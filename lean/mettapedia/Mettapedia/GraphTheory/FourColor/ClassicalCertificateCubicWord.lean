import Mathlib.GroupTheory.CoprodI
import Mathlib.GroupTheory.SpecificGroups.Cyclic
import Mettapedia.GraphTheory.FourColor.ClassicalCertificateRotationHubProfile
import Mettapedia.GraphTheory.FourColor.GoertzelV24InducedHexCorridorTypes

/-!
# Finite word certificates for cubic hypermap walks

The universal local walk algebra of a cubic hypermap is the free product
`C2 * C3`: an edge crossing has order two and a vertex turn has order three.
Reduced-word equality in this free product is decidable.  Consequently a
small checked word equality can certify that two concrete dart expressions
name the same dart, or that they lie on the same face after using the period
of a chosen root face.
-/

set_option autoImplicit false

namespace Mettapedia.GraphTheory.FourColor

namespace ClassicalCertificateCubicWord

open ClassicalCertificateRotationHubProfile
open GoertzelV24FaceDualConnectedness
open GoertzelV24HexFaceRungType
open GoertzelV24InducedHexCorridorTypes

variable {V E : Type*} [Fintype V] [DecidableEq V]
  [Fintype E] [DecidableEq E]

noncomputable section

/-- The order-two edge factor and order-three node factor. -/
def TurnFactor : Bool → Type
  | false => Multiplicative (ZMod 2)
  | true => Multiplicative (ZMod 3)

instance turnFactorGroup (index : Bool) : Group (TurnFactor index) := by
  cases index
  · exact inferInstanceAs (Group (Multiplicative (ZMod 2)))
  · exact inferInstanceAs (Group (Multiplicative (ZMod 3)))

instance turnFactorDecidableEq (index : Bool) : DecidableEq (TurnFactor index) := by
  cases index
  · exact inferInstanceAs (DecidableEq (Multiplicative (ZMod 2)))
  · exact inferInstanceAs (DecidableEq (Multiplicative (ZMod 3)))

/-- Reduced words in the free product `C2 * C3`. -/
abbrev CubicWord := Monoid.CoprodI TurnFactor

/-- One hypermap edge crossing. -/
def edge : CubicWord :=
  Monoid.CoprodI.of (i := false)
    (Multiplicative.ofAdd (1 : ZMod 2))

/-- One forward hypermap node turn.  For a stored rotation system this is
the inverse of `rho`. -/
def node : CubicWord :=
  Monoid.CoprodI.of (i := true)
    (Multiplicative.ofAdd (1 : ZMod 3))

/-- The hypermap face successor `node⁻¹ · edge`. -/
def face : CubicWord := node⁻¹ * edge

/-- The classical right quiz turn `node · edge`. -/
def qstepR : CubicWord := node * edge

/-- The classical left quiz turn `node · edge · node`. -/
def qstepL : CubicWord := node * edge * node

/-- Kernel-computable equality of reduced cubic words. -/
def equalChecker (left right : CubicWord) : Bool :=
  decide (left = right)

theorem equalChecker_sound {left right : CubicWord}
    (hcheck : equalChecker left right = true) : left = right := by
  simpa [equalChecker] using of_decide_eq_true hcheck

/-- Additive form of the cyclic representation generated by a permutation. -/
def cyclicPermutationAddHom {D : Type*} (order : Nat)
    (permutation : Equiv.Perm D) (hperiod : permutation ^ order = 1) :
    ZMod order →+ Additive (Equiv.Perm D) :=
  ZMod.lift order ⟨
    zmultiplesHom (Additive (Equiv.Perm D)) (Additive.ofMul permutation),
    by
      change (order : Int) • Additive.ofMul permutation = 0
      simpa [← ofMul_zpow] using congrArg Additive.ofMul hperiod
  ⟩

/-- A permutation of period `order` induces a representation of the cyclic
factor of that order. -/
def cyclicPermutationHom {D : Type*} (order : Nat)
    (permutation : Equiv.Perm D) (hperiod : permutation ^ order = 1) :
    Multiplicative (ZMod order) →* Equiv.Perm D :=
  AddMonoidHom.toMultiplicativeLeft <|
    cyclicPermutationAddHom order permutation hperiod

@[simp] theorem cyclicPermutationAddHom_generator {D : Type*} (order : Nat)
    (permutation : Equiv.Perm D) (hperiod : permutation ^ order = 1) :
    cyclicPermutationAddHom order permutation hperiod (1 : ZMod order) =
      Additive.ofMul permutation := by
  rw [show (1 : ZMod order) = ((1 : Int) : ZMod order) by norm_num]
  rw [cyclicPermutationAddHom, ZMod.lift_coe]
  simp [zmultiplesHom_apply]

@[simp] theorem cyclicPermutationHom_generator {D : Type*} (order : Nat)
    (permutation : Equiv.Perm D) (hperiod : permutation ^ order = 1) :
    cyclicPermutationHom order permutation hperiod
        (Multiplicative.ofAdd (1 : ZMod order)) = permutation := by
  change (cyclicPermutationAddHom order permutation hperiod
    (1 : ZMod order)).toMul = permutation
  rw [cyclicPermutationAddHom_generator]
  rfl

/-- The edge permutation has period two. -/
theorem alpha_sq_eq_one (RS : RotationSystem V E) : RS.alpha ^ 2 = 1 := by
  ext dart
  simp [pow_succ, Equiv.Perm.mul_apply, RS.alpha_involutive]

/-- The inverse vertex rotation has period three in a cubic cyclic rotation
system. -/
theorem rho_symm_cube_eq_one (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    RS.rho.symm ^ 3 = 1 := by
  have hforward : RS.rho ^ 3 = 1 := by
    ext dart
    simpa [pow_succ, Equiv.Perm.mul_apply] using
      rho_cube_apply_of_isCubic RS hcubic hrotation dart
  change (RS.rho⁻¹) ^ 3 = 1
  rw [inv_pow, hforward]
  simp

/-- The two cyclic factors act by the actual edge and inverse vertex
permutations. -/
def factorRepresentation (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    (index : Bool) → TurnFactor index →* Equiv.Perm RS.D
  | false => cyclicPermutationHom 2 RS.alpha (alpha_sq_eq_one RS)
  | true => cyclicPermutationHom 3 RS.rho.symm
      (rho_symm_cube_eq_one RS hcubic hrotation)

/-- Interpretation of a reduced cubic word as a dart permutation. -/
def evaluate (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    CubicWord →* Equiv.Perm RS.D :=
  Monoid.CoprodI.lift (factorRepresentation RS hcubic hrotation)

@[simp] theorem evaluate_edge (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    evaluate RS hcubic hrotation edge = RS.alpha := by
  rw [evaluate, edge, Monoid.CoprodI.lift_of]
  exact cyclicPermutationHom_generator 2 RS.alpha (alpha_sq_eq_one RS)

@[simp] theorem evaluate_node (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    evaluate RS hcubic hrotation node = RS.rho.symm := by
  rw [evaluate, node, Monoid.CoprodI.lift_of]
  exact cyclicPermutationHom_generator 3 RS.rho.symm
    (rho_symm_cube_eq_one RS hcubic hrotation)

@[simp] theorem evaluate_face (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    evaluate RS hcubic hrotation face = RS.phi := by
  ext dart
  simp [face, RotationSystem.phi_apply]

@[simp] theorem evaluate_qstepR (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    evaluate RS hcubic hrotation qstepR =
      RS.rho.symm * RS.alpha := by
  simp [qstepR]

@[simp] theorem evaluate_qstepL (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS) :
    evaluate RS hcubic hrotation qstepL =
      RS.rho.symm * RS.alpha * RS.rho.symm := by
  simp [qstepL]

/-- Apply a certified cubic word to a chosen root dart. -/
def act (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS)
    (word : CubicWord) (root : RS.D) : RS.D :=
  evaluate RS hcubic hrotation word root

theorem act_mul (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS)
    (left right : CubicWord) (root : RS.D) :
    act RS hcubic hrotation (left * right) root =
      act RS hcubic hrotation left
        (act RS hcubic hrotation right root) := by
  simp [act, Equiv.Perm.mul_apply]

@[simp] theorem act_act (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS)
    (left right : CubicWord) (root : RS.D) :
    act RS hcubic hrotation left
        (act RS hcubic hrotation right root) =
      act RS hcubic hrotation (left * right) root :=
  (act_mul RS hcubic hrotation left right root).symm

@[simp] theorem act_zpow (RS : RotationSystem V E)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS)
    (word : CubicWord) (power : Int) (root : RS.D) :
    act RS hcubic hrotation (word ^ power) root =
      (evaluate RS hcubic hrotation word ^ power) root := by
  simp [act]

/-- Facial arity is unchanged by any signed number of face steps. -/
theorem faceArity_phi_zpow (RS : RotationSystem V E)
    (power : Int) (dart : RS.D) :
    faceArity RS ((RS.phi ^ power) dart) = faceArity RS dart := by
  unfold faceArity
  rw [RS.faceOrbit_of_mem]
  exact (RS.mem_faceOrbit).2
    ((Equiv.Perm.SameCycle.refl RS.phi dart).zpow_right)

/-- An integral multiple of the actual root-face period fixes the root. -/
theorem phi_zpow_mul_faceOrbit_card_apply
    (RS : RotationSystem V E) (root : RS.D) (multiple : Int) :
    (RS.phi ^ ((RS.faceOrbit root).card * multiple)) root = root := by
  apply ((faceOrbit_isCycleOn RS root).zpow_apply_eq
    (RS.mem_faceOrbit_self root)).2
  exact dvd_mul_right _ _

/-- A checked double-coset equality proves equality of observed face
arities.  The right face-period factor fixes the root; the left face factor
only moves within the target face. -/
theorem faceArity_act_eq_of_match
    (RS : RotationSystem V E) (hcubic : RS.IsCubic)
    (hrotation : VertexRotationCyclic RS) (root : RS.D)
    (observed target : CubicWord) (leftSteps rightPeriods : Int)
    (hcheck : equalChecker observed
      (face ^ leftSteps * target *
        face ^ ((RS.faceOrbit root).card * rightPeriods)) = true) :
    faceArity RS (act RS hcubic hrotation observed root) =
      faceArity RS (act RS hcubic hrotation target root) := by
  have hword := equalChecker_sound hcheck
  rw [hword]
  simp only [act_mul, act_zpow, evaluate_face]
  rw [phi_zpow_mul_faceOrbit_card_apply]
  exact faceArity_phi_zpow RS leftSteps _

/-- Version of `faceArity_act_eq_of_match` whose checked period is an explicit
natural number.  This is the form used by finite certificates. -/
theorem faceArity_act_eq_of_match_size
    (RS : RotationSystem V E) (hcubic : RS.IsCubic)
    (hrotation : VertexRotationCyclic RS) (root : RS.D)
    (hubSize : Nat) (hcard : (RS.faceOrbit root).card = hubSize)
    (observed target : CubicWord) (leftSteps rightPeriods : Int)
    (hcheck : equalChecker observed
      (face ^ leftSteps * target *
        face ^ (hubSize * rightPeriods)) = true) :
    faceArity RS (act RS hcubic hrotation observed root) =
      faceArity RS (act RS hcubic hrotation target root) := by
  apply faceArity_act_eq_of_match RS hcubic hrotation root observed target
    leftSteps rightPeriods
  simpa [hcard] using hcheck

end

end ClassicalCertificateCubicWord

end Mettapedia.GraphTheory.FourColor
