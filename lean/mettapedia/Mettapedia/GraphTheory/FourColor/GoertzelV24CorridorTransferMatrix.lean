/-- A finite weighted transfer. Its entry is the number of one-step
realizations with the specified source and target profiles. -/
abbrev TransferMatrix (Profile : Type*) := Matrix Profile Profile Nat

/-- The number of weighted transfer realizations of an exact length. -/
def transferCount
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (step : TransferMatrix Profile) (length : Nat)
    (start finish : Profile) : Nat :=
  (step ^ length) start finish

/-- Matrix multiplication is the exact compositional law for transfer
counts: split a realization at the intermediate interface and sum over all
possible profiles there. -/
theorem transferCount_add
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (step : TransferMatrix Profile) (firstLength secondLength : Nat)
    (start finish : Profile) :
    transferCount step (firstLength + secondLength) start finish =
      ∑ middle : Profile,
        transferCount step firstLength start middle *
          transferCount step secondLength middle finish := by
  simp only [transferCount, pow_add, Matrix.mul_apply]

@[simp]
theorem exactRelationalTransfer_zero_iff
    {Profile : Type*} {oneStep : Profile → Profile → Prop}
    {start finish : Profile} :
    ExactRelationalTransfer oneStep 0 start finish ↔ start = finish := by
  constructor
  · intro hpath
    cases hpath
    rfl
  · intro heq
    subst finish
    exact ExactRelationalTransfer.zero start

/-- The support of the matrix-power count is exactly the relational transfer
generated by the positive one-step entries. This connects weighted counting
semantics to the existing exact-path semantics without discarding
multiplicity. -/
theorem transferCount_pos_iff_exactRelationalTransfer
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (step : TransferMatrix Profile) (length : Nat)
    (start finish : Profile) :
    0 < transferCount step length start finish ↔
      ExactRelationalTransfer (fun source target => 0 < step source target)
        length start finish := by
  induction length generalizing start with
  | zero =>
      rw [exactRelationalTransfer_zero_iff]
      change (0 < (1 : Matrix Profile Profile Nat) start finish) ↔ _
      rw [Matrix.one_apply]
      by_cases heq : start = finish
      · simp [heq]
      · simp [heq]
  | succ length ih =>
      change 0 < (step ^ (length + 1)) start finish ↔ _
      rw [pow_succ', Matrix.mul_apply, Finset.sum_pos_iff]
      simp only [Finset.mem_univ, true_and]
      constructor
      · rintro ⟨middle, hproduct⟩
        exact ExactRelationalTransfer.succ
          (Nat.pos_of_mul_pos_right hproduct)
          ((ih middle).mp (Nat.pos_of_mul_pos_left hproduct))
      · intro hpath
        cases hpath with
        | @succ _ _ middle _ hstep htail =>
            exact ⟨middle, Nat.mul_pos hstep ((ih middle).mpr htail)⟩

/-- Boolean support matrix of a finite relational transfer. -/
def relationalTransferMatrix
    {Profile : Type*} [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep] :
    TransferMatrix Profile :=
  fun source target => if oneStep source target then 1 else 0

@[simp]
theorem relationalTransferMatrix_pos_iff
    {Profile : Type*} [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep]
    (source target : Profile) :
    0 < relationalTransferMatrix oneStep source target ↔
      oneStep source target := by
  unfold relationalTransferMatrix
  by_cases hstep : oneStep source target
  · simp [hstep]
  · simp [hstep]

/-- A relational transfer exists exactly when the corresponding entry of its
finite support matrix power is positive. -/
theorem relationalTransferMatrix_pow_pos_iff
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep]
    (length : Nat) (start finish : Profile) :
    0 < transferCount (relationalTransferMatrix oneStep) length start finish ↔
      ExactRelationalTransfer oneStep length start finish := by
  rw [transferCount_pos_iff_exactRelationalTransfer]
  simp only [relationalTransferMatrix_pos_iff]

/-- Every valid-to-valid entry of the squared abstract slab transfer matrix
is positive. This is the matrix form of two-step completeness and records
that the unaugmented local color profile has no obstruction beyond one
step. -/
theorem validHexSlab_transferCount_two_pos
    (source target : HexSlabColorState)
    (hsource : source.Valid) (htarget : target.Valid) :
    0 < transferCount
      (relationalTransferMatrix FlankingTaitColorTransition)
      2 source target := by
  apply (relationalTransferMatrix_pow_pos_iff
    FlankingTaitColorTransition 2 source target).2
  rcases flankingTaitColorTransition_twoStep_complete
    source target hsource htarget with ⟨middle, hfirst, hsecond⟩
  exact ExactRelationalTransfer.succ hfirst
    (ExactRelationalTransfer.succ hsecond
      (ExactRelationalTransfer.zero target))

/-- The deterministic reachable-profile computation is exactly the support
of the relational transfer matrix applied to the initial profiles. -/
theorem mem_reachableProfilesAfter_iff_transferCount_pos
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep]
    (initial : Finset Profile) (length : Nat) (finish : Profile) :
    finish ∈ reachableProfilesAfter oneStep initial length ↔
      ∃ start ∈ initial,
        0 < transferCount (relationalTransferMatrix oneStep)
          length start finish := by
  rw [mem_reachableProfilesAfter_iff]
  constructor
  · rintro ⟨start, hstart, hpath⟩
    exact ⟨start, hstart,
      (relationalTransferMatrix_pow_pos_iff oneStep length start finish).2
        hpath⟩
  · rintro ⟨start, hstart, hcount⟩
    exact ⟨start, hstart,
      (relationalTransferMatrix_pow_pos_iff oneStep length start finish).1
        hcount⟩

/-- Total number of exact relational paths from the initial set to an
accepting profile. Each allowed one-step transition has unit multiplicity. -/
def relationalTransferAcceptanceCount
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep]
    (initial : Finset Profile) (isAccepting : Profile → Prop)
    [DecidablePred isAccepting] (length : Nat) : Nat :=
  ∑ start ∈ initial,
    ∑ finish : { profile : Profile // isAccepting profile },
      transferCount (relationalTransferMatrix oneStep)
        length start finish.1

/-- Existing Boolean acceptance is precisely nonvanishing of the finite
matrix count. Thus the current pumping language is the support of the
compositional counting semantics. -/
theorem relationalTransferAcceptanceCount_pos_iff
    {Profile : Type*} [Fintype Profile] [DecidableEq Profile]
    (oneStep : Profile → Profile → Prop) [DecidableRel oneStep]
    (initial : Finset Profile) (isAccepting : Profile → Prop)
    [DecidablePred isAccepting] (length : Nat) :
    0 < relationalTransferAcceptanceCount oneStep initial isAccepting length ↔
      TransferAcceptsInExactly oneStep initial isAccepting length := by
  constructor
  · intro hcount
    simp only [relationalTransferAcceptanceCount, Finset.sum_pos_iff,
      Finset.mem_univ, true_and] at hcount
    rcases hcount with ⟨start, hstart, finish, hpositive⟩
    exact ⟨finish.1,
      (mem_reachableProfilesAfter_iff_transferCount_pos
        oneStep initial length finish.1).2 ⟨start, hstart, hpositive⟩,
      finish.2⟩
  · rintro ⟨finish, hreachable, haccepting⟩
    rcases (mem_reachableProfilesAfter_iff_transferCount_pos
      oneStep initial length finish).1 hreachable with
      ⟨start, hstart, hpositive⟩
    simp only [relationalTransferAcceptanceCount, Finset.sum_pos_iff,
      Finset.mem_univ, true_and]
    exact ⟨start, hstart, ⟨finish, haccepting⟩, hpositive⟩

/-- Every real Tait coloring of a clean hex corridor contributes a positive
entry between its graph-extracted endpoint states in the finite flanking
transition matrix. This is the concrete graph-to-matrix direction of the
corridor counting semantics. -/
theorem hexCorridorColorStateWord_transferCount_pos
    {V E : Type*} [Fintype V] [DecidableEq V]
    [Fintype E] [DecidableEq E]
    {RS : RotationSystem V E} {corridorLength : Nat}
    (clean : CleanOrbitHexCorridorSkeleton RS corridorLength)
    (hcubic : RS.IsCubic) (hrotation : VertexRotationCyclic RS)
    (htwoSided : OrbitFacesTwoSided RS)
    (hunique : PairwiseUniqueSharedInteriorEdges (orbitFaceBoundary RS)
      (Finset.univ : Finset (OrbitFace RS)))
    (C : RS.EdgeColoring Color) (hC : RS.IsTaitEdgeColoring C)
    (hlength : 3 ≤ corridorLength) :
    0 < transferCount
      (relationalTransferMatrix FlankingTaitColorTransition)
      (corridorLength - 3)
      (hexCorridorColorStateWord clean htwoSided hunique C hC
        (firstInternalOffsetOfLength hlength))
      (hexCorridorColorStateWord clean htwoSided hunique C hC
        (lastInternalOffsetOfLength hlength)) := by
  apply (relationalTransferMatrix_pow_pos_iff
    FlankingTaitColorTransition (corridorLength - 3) _ _).2
  exact hexCorridorColorStateWord_exactTransfer clean hcubic hrotation
    htwoSided hunique C hC hlength

