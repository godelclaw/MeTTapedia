theorem mmFiber32ExtractAllLefts_eq_nil :
    lengthTwoFiberExtractLeftStateList mmWord mmFiber32Key allTauStates = [] := by
  rw [allTauStates_eq_chunks32]
  repeat rw [lengthTwoFiberExtractLeftStateList_append]
  decide

theorem mmFiber32RealFiberConnected :
    chainFiberConnected mmWord (chainFiberFrom mmWord (allChainStates mmWord) mmFiber32Key) = true := by
  exact mmEmptyFiberConnected_of_extract_nil mmFiber32ExtractAllLefts_eq_nil

