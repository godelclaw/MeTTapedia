attribute [local instance]
  fusionFaceNetworkGraphEdgeSetDecidableEq
  fusionFaceNetworkRetainedVertexFintype
  fusionFaceNetworkRetainedVertexDecidableEq

/-- Supporting face of a complete exact-rebase channel state. -/
abbrev CrossCentralExactFaceCutChannelState.face
    {graphData : Data G} {data : AdjacentPairData G}
    (state : CrossCentralExactFaceCutChannelState graphData data) :
    OrbitFace graphData.toRotationSystem :=
  state.1

/-- Retained cross edge of a complete exact-rebase channel state. -/
abbrev CrossCentralExactFaceCutChannelState.cross
    {graphData : Data G} {data : AdjacentPairData G}
    (state : CrossCentralExactFaceCutChannelState graphData data) :
    (DeletedAdjacentPairGraph G data.firstVertex
      data.secondVertex).edgeSet :=
  state.2.1.1

/-- Exact cut pair carried by a complete exact-rebase channel state. -/
abbrev CrossCentralExactFaceCutChannelState.pair
    {graphData : Data G} {data : AdjacentPairData G}
    (state : CrossCentralExactFaceCutChannelState graphData data) :
    CrossCentralExactFaceCutPair graphData data state.cross :=
  state.2.1.2

/-- The state's cross edge lies on its recorded supporting face. -/
theorem CrossCentralExactFaceCutChannelState.cross_mem_face
    {graphData : Data G} {data : AdjacentPairData G}
    (state : CrossCentralExactFaceCutChannelState graphData data) :
    retainedEdgeToAmbientEdge data state.cross ∈
      orbitFaceBoundary graphData.toRotationSystem state.face :=
  state.2.2

/-- A geometric exact rebase arising from one localized successor pair.
The target remains on the source face, changes the retained cross, and uses
the two successor trails verbatim. -/
structure CrossCentralExactFaceRebaseStep
    (graphData : Data G) (data : AdjacentPairData G)
    (source : CrossCentralExactFaceCutChannelState graphData data)
    {firstRoot secondRoot : V}
    {firstFusion : G.Walk firstRoot firstRoot}
    {secondFusion : G.Walk secondRoot secondRoot}
    (successors : LocalizedFusionSuccessorResolution source.pair source.face
      firstFusion secondFusion) where
  targetCross : (DeletedAdjacentPairGraph G data.firstVertex
    data.secondVertex).edgeSet
  targetPair : CrossCentralExactFaceCutPair graphData data targetCross
  targetCross_ne : targetCross ≠ source.cross
  targetCross_mem_face : retainedEdgeToAmbientEdge data targetCross ∈
    orbitFaceBoundary graphData.toRotationSystem source.face
  target_prefixTrail : targetPair.prefixTrail = successors.prefixSuccessor
  target_suffixTrail : targetPair.suffixTrail = successors.suffixSuccessor

/-- Complete target channel state of one exact rebase step. -/
def CrossCentralExactFaceRebaseStep.target
    {graphData : Data G} {data : AdjacentPairData G}
    {source : CrossCentralExactFaceCutChannelState graphData data}
    {firstRoot secondRoot : V}
    {firstFusion : G.Walk firstRoot firstRoot}
    {secondFusion : G.Walk secondRoot secondRoot}
    {successors : LocalizedFusionSuccessorResolution source.pair source.face
      firstFusion secondFusion}
    (step : CrossCentralExactFaceRebaseStep graphData data source
      successors) :
    CrossCentralExactFaceCutChannelState graphData data :=
  ⟨source.face,
    ⟨⟨step.targetCross, step.targetPair⟩, step.targetCross_mem_face⟩⟩

/-- Binary transition relation generated by exact geometric rebases. -/
def CrossCentralExactFaceRebaseTransition
    (graphData : Data G) (data : AdjacentPairData G)
    (source target : CrossCentralExactFaceCutChannelState graphData data) :
    Prop :=
  ∃ (firstRoot secondRoot : V)
      (firstFusion : G.Walk firstRoot firstRoot)
      (secondFusion : G.Walk secondRoot secondRoot)
      (successors : LocalizedFusionSuccessorResolution source.pair
        source.face firstFusion secondFusion)
      (step : CrossCentralExactFaceRebaseStep graphData data source
        successors),
    step.target = target

/-- Every packaged step realizes the exact-rebase transition relation. -/
theorem CrossCentralExactFaceRebaseStep.to_transition
    {graphData : Data G} {data : AdjacentPairData G}
    {source : CrossCentralExactFaceCutChannelState graphData data}
    {firstRoot secondRoot : V}
    {firstFusion : G.Walk firstRoot firstRoot}
    {secondFusion : G.Walk secondRoot secondRoot}
    {successors : LocalizedFusionSuccessorResolution source.pair source.face
      firstFusion secondFusion}
    (step : CrossCentralExactFaceRebaseStep graphData data source
      successors) :
    CrossCentralExactFaceRebaseTransition graphData data source step.target :=
  ⟨firstRoot, secondRoot, firstFusion, secondFusion, successors, step, rfl⟩

/-- An exact rebase preserves the selected supporting face. -/
theorem CrossCentralExactFaceRebaseTransition.face_eq
    {graphData : Data G} {data : AdjacentPairData G}
    {source target : CrossCentralExactFaceCutChannelState graphData data}
    (transition : CrossCentralExactFaceRebaseTransition graphData data
      source target) :
    target.face = source.face := by
  rcases transition with
    ⟨firstRoot, secondRoot, firstFusion, secondFusion, successors, step, rfl⟩
  rfl

/-- An exact rebase changes the retained cross edge. -/
theorem CrossCentralExactFaceRebaseTransition.cross_ne
    {graphData : Data G} {data : AdjacentPairData G}
    {source target : CrossCentralExactFaceCutChannelState graphData data}
    (transition : CrossCentralExactFaceRebaseTransition graphData data
      source target) :
    target.cross ≠ source.cross := by
  rcases transition with
    ⟨firstRoot, secondRoot, firstFusion, secondFusion, successors, step, rfl⟩
  exact step.targetCross_ne

/-- In particular, the exact-rebase relation has no one-step loop. -/
theorem CrossCentralExactFaceRebaseTransition.irrefl
    {graphData : Data G} {data : AdjacentPairData G}
    (state : CrossCentralExactFaceCutChannelState graphData data) :
    ¬CrossCentralExactFaceRebaseTransition graphData data state state := by
  intro transition
  exact transition.cross_ne rfl

/-- The exact successor trichotomy expressed as a terminal outcome or one
transition on the complete finite channel state. -/
inductive LocalizedFusionSuccessorTerminalOrRebase
    (graphData : Data G) (data : AdjacentPairData G)
    (source : CrossCentralExactFaceCutChannelState graphData data)
    {firstRoot secondRoot : V}
    {firstFusion : G.Walk firstRoot firstRoot}
    {secondFusion : G.Walk secondRoot secondRoot}
    (successors : LocalizedFusionSuccessorResolution source.pair source.face
      firstFusion secondFusion)
    (firstIndex secondIndex : Fin 2) : Prop where
  | disjoint
      (edges_disjoint : successors.prefixSuccessor.edges.Disjoint
        successors.suffixSuccessor.edges)
  | rebase
      (step : CrossCentralExactFaceRebaseStep graphData data source
        successors)
  | cleanRouteOnly
      (successor : LocalizedSuccessorFusionChainProfile source.cross
        source.face successors.prefixSuccessor successors.suffixSuccessor)
      (signed : LocalizedFusionChainSignedTransferResolution
        successor.pair source.cross source.face)
      (clean_diagonal : signed.CleanTransferIsDiagonal)
      (closed_route_only : signed.CleanClosedTransferIsRouteOnly
        firstIndex secondIndex)

/-- Convert the route-only successor outcome into the terminal-or-transition
form on the complete finite state. -/
theorem LocalizedFusionSuccessorResolution.terminalOrRebase_of_routeOnlyComposition
    {graphData : Data G} {data : AdjacentPairData G}
    {source : CrossCentralExactFaceCutChannelState graphData data}
    {firstRoot secondRoot : V}
    {firstFusion : G.Walk firstRoot firstRoot}
    {secondFusion : G.Walk secondRoot secondRoot}
    (successors : LocalizedFusionSuccessorResolution source.pair source.face
      firstFusion secondFusion)
    (firstIndex secondIndex : Fin 2)
    (houtcome : successors.RouteOnlyCompositionOutcome
      firstIndex secondIndex) :
    LocalizedFusionSuccessorTerminalOrRebase graphData data source
      successors firstIndex secondIndex := by
  unfold LocalizedFusionSuccessorResolution.RouteOnlyCompositionOutcome at houtcome
  rcases houtcome with hdisjoint | hrebase | hclean
  · exact .disjoint hdisjoint
  · rcases hrebase with
      ⟨targetCross, targetPair, hne, hmem, hprefix, hsuffix⟩
    exact .rebase {
      targetCross := targetCross
      targetPair := targetPair
      targetCross_ne := hne
      targetCross_mem_face := hmem
      target_prefixTrail := hprefix
      target_suffixTrail := hsuffix }
  · rcases hclean with ⟨successor, signed, hdiagonal, hrouteOnly⟩
    exact .cleanRouteOnly successor signed hdiagonal hrouteOnly

/-- Complete finite channel state selected by a remote transfer witness. -/
def CrossSideRemoteFusionChainTransferWitness.channelState
    {graphData : Data G} {data : AdjacentPairData G}
    {cross : (DeletedAdjacentPairGraph G data.firstVertex
      data.secondVertex).edgeSet}
    {pair : CrossCentralExactFaceCutPair graphData data cross}
    (witness : CrossSideRemoteFusionChainTransferWitness graphData data
      cross pair) :
    CrossCentralExactFaceCutChannelState graphData data :=
  ⟨edgeCrossFaceCoordinateOrbitFace graphData
      (retainedEdgeToAmbientEdge data cross) witness.coordinate,
    ⟨⟨cross, pair⟩, witness.cross_mem_coordinate_face⟩⟩

/-- Closed-monodromy normal form with its only nonterminal branch exposed as
one transition on the finite exact-rebase state space. -/
inductive CrossSideRemoteFusionChainTransferWitness.FiniteRebaseTransitionOutcome
    {graphData : Data G} {data : AdjacentPairData G}
    {cross : (DeletedAdjacentPairGraph G data.firstVertex
      data.secondVertex).edgeSet}
    {pair : CrossCentralExactFaceCutPair graphData data cross}
    (witness : CrossSideRemoteFusionChainTransferWitness graphData data
      cross pair) : Prop where
  | mixed
      (indices_ne : witness.firstIndex ≠ witness.secondIndex)
      (closed_identity : rejectedCrossCentralReturnClosedTransfer
        witness.firstIndex witness.secondIndex = Equiv.refl (Bool × Bool))
  | firstRetained
      (active : CrossSideRemoteFusionChainActiveState witness)
      (resolution : CrossSideRemoteFusionChainResolution graphData data
        cross pair witness.coordinate)
      (hroot : resolution.firstRoot ∈
        retainedVertexSet data.firstVertex data.secondVertex)
      (retainedFusion : (DeletedAdjacentPairGraph G data.firstVertex
        data.secondVertex).Walk ⟨resolution.firstRoot, hroot⟩
          ⟨resolution.firstRoot, hroot⟩)
      (isCycle : retainedFusion.IsCycle)
      (ambient_eq : data.retainedWalkToAmbient retainedFusion =
        resolution.firstFusion)
  | secondRetained
      (active : CrossSideRemoteFusionChainActiveState witness)
      (resolution : CrossSideRemoteFusionChainResolution graphData data
        cross pair witness.coordinate)
      (hroot : resolution.secondRoot ∈
        retainedVertexSet data.firstVertex data.secondVertex)
      (retainedFusion : (DeletedAdjacentPairGraph G data.firstVertex
        data.secondVertex).Walk ⟨resolution.secondRoot, hroot⟩
          ⟨resolution.secondRoot, hroot⟩)
      (isCycle : retainedFusion.IsCycle)
      (ambient_eq : data.retainedWalkToAmbient retainedFusion =
        resolution.secondFusion)
  | successors
      (active : CrossSideRemoteFusionChainActiveState witness)
      (resolution : CrossSideRemoteFusionChainResolution graphData data
        cross pair witness.coordinate)
      (successors : LocalizedFusionSuccessorResolution pair
        (edgeCrossFaceCoordinateOrbitFace graphData
          (retainedEdgeToAmbientEdge data cross) witness.coordinate)
        resolution.firstFusion resolution.secondFusion)
      (terminalOrRebase : LocalizedFusionSuccessorTerminalOrRebase
        graphData data witness.channelState successors witness.firstIndex
          witness.secondIndex)

/-- Every remote witness in a minimal spherical counterexample has the
finite terminal-or-exact-rebase transition normal form. -/
theorem CrossSideRemoteFusionChainTransferWitness.finiteRebaseTransition_outcome_of_minimal
    (graphData : Data G)
    (minimal : GraphBackedVertexMinimalTaitCounterexample graphData)
    (baseData : AdjacentPairData G)
    {cross : (DeletedAdjacentPairGraph G
      (baseData.rotationOrderedData graphData minimal.spherical.cubic
        minimal.vertexRotationCyclic).firstVertex
      (baseData.rotationOrderedData graphData minimal.spherical.cubic
        minimal.vertexRotationCyclic).secondVertex).edgeSet}
    {pair : CrossCentralExactFaceCutPair graphData
      (baseData.rotationOrderedData graphData minimal.spherical.cubic
        minimal.vertexRotationCyclic) cross}
    (witness : CrossSideRemoteFusionChainTransferWitness graphData
      (baseData.rotationOrderedData graphData minimal.spherical.cubic
        minimal.vertexRotationCyclic) cross pair) :
    witness.FiniteRebaseTransitionOutcome := by
  have hclosed := witness.finiteClosedMonodromy_outcome_of_minimal
    graphData minimal baseData
  unfold CrossSideRemoteFusionChainTransferWitness.FiniteClosedMonodromyOutcome
    at hclosed
  rcases hclosed with hmixed | hactive
  · exact .mixed hmixed.1 hmixed.2
  · rcases hactive with ⟨active, resolution, houtcome⟩
    unfold CrossSideRemoteFusionChainResolution.RouteOnlyCompositionOutcome at houtcome
    rcases houtcome with hfirst | hsecond | hsuccessors
    · rcases hfirst with ⟨hroot, retainedFusion, hcycle, hambient⟩
      exact .firstRetained active resolution hroot retainedFusion hcycle
        hambient
    · rcases hsecond with ⟨hroot, retainedFusion, hcycle, hambient⟩
      exact .secondRetained active resolution hroot retainedFusion hcycle
        hambient
    · rcases hsuccessors with ⟨successors, hterminal⟩
      have hterminal' : LocalizedFusionSuccessorTerminalOrRebase graphData
          (baseData.rotationOrderedData graphData minimal.spherical.cubic
            minimal.vertexRotationCyclic)
          witness.channelState successors witness.firstIndex
            witness.secondIndex :=
        LocalizedFusionSuccessorResolution.terminalOrRebase_of_routeOnlyComposition
          (graphData := graphData)
          (data := baseData.rotationOrderedData graphData
            minimal.spherical.cubic minimal.vertexRotationCyclic)
          (source := witness.channelState) successors witness.firstIndex
            witness.secondIndex hterminal
      exact .successors active resolution successors
        hterminal'

/-- The source-closure alternative with every remote witness refined to a
terminal outcome or one transition on the finite exact-rebase state. -/
theorem CrossCentralExactFaceCutPair.sourceClosureCycleDescent_or_exists_finiteRebaseTransition
    {graphData : Data G}
    (minimal : GraphBackedVertexMinimalTaitCounterexample graphData)
    (baseData : GoertzelV24AdjacentPairBoundary.AdjacentPairData G)
    {cross : (DeletedAdjacentPairGraph G baseData.firstVertex
      baseData.secondVertex).edgeSet}
    (pair : CrossCentralExactFaceCutPair graphData
      (baseData.rotationOrderedData graphData minimal.spherical.cubic
        minimal.vertexRotationCyclic) cross) :
    CrossCentralSourceClosureCycleDescent pair ∨
      (∃ witness : CrossSideRemoteFusionChainTransferWitness graphData
          (baseData.rotationOrderedData graphData minimal.spherical.cubic
            minimal.vertexRotationCyclic) cross pair,
        witness.FiniteRebaseTransitionOutcome) := by
  rcases pair.sourceClosureCycleDescent_or_exists_finiteClosedMonodromy
      minimal baseData with hdescent | hwitness
  · exact Or.inl hdescent
  · rcases hwitness with ⟨witness, _hclosed⟩
    exact Or.inr ⟨witness,
      witness.finiteRebaseTransition_outcome_of_minimal
        graphData minimal baseData⟩

end GoertzelV24AdjacentPairInsertion.AdjacentPairData

