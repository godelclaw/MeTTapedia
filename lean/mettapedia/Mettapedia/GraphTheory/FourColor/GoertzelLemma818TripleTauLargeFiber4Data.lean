def tttLargeFiber4ParentOf (i : Nat) : Nat :=
  if 2176 <= i ∧ i < 2240 then
    tttLargeFiber4ParentOfLow0Offset (i - 2176)
  else if 2240 <= i ∧ i < 2304 then
    tttLargeFiber4ParentOfLow1Offset (i - 2240)
  else if 2304 <= i ∧ i < 2368 then
    tttLargeFiber4ParentOfLow2Offset (i - 2304)
  else if 2368 <= i ∧ i < 2432 then
    tttLargeFiber4ParentOfLow3Offset (i - 2368)
  else if 3824 <= i ∧ i < 3888 then
    tttLargeFiber4ParentOfHigh0Offset (i - 3824)
  else if 3888 <= i ∧ i < 3952 then
    tttLargeFiber4ParentOfHigh1Offset (i - 3888)
  else if 3952 <= i ∧ i < 4016 then
    tttLargeFiber4ParentOfHigh2Offset (i - 3952)
  else if 4016 <= i ∧ i < 4080 then
    tttLargeFiber4ParentOfHigh3Offset (i - 4016)
  else
    i
def tttLargeFiber4ParentIter : Nat -> Nat -> Nat
  | 0, i => i
  | n + 1, i => tttLargeFiber4ParentIter n (tttLargeFiber4ParentOf i)

def tttLargeFiber4ParentConvergesCheck (i : Nat) : Bool :=
  tttLargeFiber4ParentIter tttLargeFiber4MaxParentDepth
    (listGetD tttLargeFiber4Expected i 0) == tttLargeFiber4Root

