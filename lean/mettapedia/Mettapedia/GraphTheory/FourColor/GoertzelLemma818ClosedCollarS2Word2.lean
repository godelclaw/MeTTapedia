theorem closedStates_chunk0 :
    ((allClosedCollarStates word).drop 0).take 32 =
      listGetD closedStateChunks 0 [] := by
  decide

theorem closedStates_chunk1 :
    ((allClosedCollarStates word).drop 32).take 32 =
