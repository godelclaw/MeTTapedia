import Mettapedia.GraphTheory.FourColor.BoundaryChainPeel
import Mettapedia.GraphTheory.FourColor.Orthogonality
import Mettapedia.GraphTheory.FourColor.Theorem49Certificate

namespace Mettapedia.GraphTheory.FourColor

variable {V F E : Type*} [DecidableEq V]

/-- The finite set of face-boundary supports listed by an ordered face peel.

This is the algebraic face-boundary span attached to the certificate order. It
does not claim that the certificate supplies a `BoundaryChainAggregatePeelData`
instance; support decrease and tightness remain separate obligations. -/
noncomputable def faceOrderBoundarySet
    (faceBoundary : F → Finset E) (faceOrder : List F) :
    Finset (Finset E) := by
  classical
  exact faceOrder.toFinset.image faceBoundary

theorem mem_faceOrderBoundarySet_iff
    (faceBoundary : F → Finset E) (faceOrder : List F) {B : Finset E} :
    B ∈ faceOrderBoundarySet faceBoundary faceOrder ↔
      ∃ f ∈ faceOrder, faceBoundary f = B := by
  classical
  simp [faceOrderBoundarySet]

/-- Every face listed in an ordered peel contributes its face-boundary chain to
the finite span generated by the ordered peel's face boundaries. -/
theorem faceBoundaryChain_mem_faceBoundarySpan_of_mem_faceOrder
    [DecidableEq E] {γ : Color} (faceBoundary : F → Finset E)
    {faceOrder : List F} {f : F} (hf : f ∈ faceOrder) :
    faceBoundaryChain γ (faceBoundary f) ∈
      faceBoundarySpan γ (faceOrderBoundarySet faceBoundary faceOrder) := by
  classical
  refine ⟨{faceBoundary f}, ?_, ?_⟩
  · intro B hB
    rw [Finset.mem_singleton] at hB
    subst B
    exact (mem_faceOrderBoundarySet_iff faceBoundary faceOrder).2 ⟨f, hf, rfl⟩
  · simp

/-- The finite sum of boundary chains over any finite set of faces listed in
an ordered peel lies in the span generated by that peel's face boundaries.

This is the certificate-facing aggregate version of
`faceBoundaryChain_mem_faceBoundarySpan_of_mem_faceOrder`. It permits repeated
face-boundary supports: over `𝔽₂²`, repeated toggles are handled by the span's
addition closure rather than by assuming `faceBoundary` is injective. -/
theorem faceBoundarySum_mem_faceBoundarySpan_of_subset_faceOrder
    [DecidableEq E] {γ : Color} (faceBoundary : F → Finset E)
    {faceOrder : List F} {S : Finset F}
    (hS : ∀ f ∈ S, f ∈ faceOrder) :
    (∑ f ∈ S, faceBoundaryChain γ (faceBoundary f)) ∈
      faceBoundarySpan γ (faceOrderBoundarySet faceBoundary faceOrder) := by
  classical
  induction S using Finset.induction with
  | empty =>
      simpa using
        (zeroChain_mem_faceBoundarySpan
          (γ := γ) (faces := faceOrderBoundarySet faceBoundary faceOrder))
  | insert f S hnot ih =>
      have hS_tail : ∀ g ∈ S, g ∈ faceOrder :=
        fun g hg => hS g (Finset.mem_insert_of_mem hg)
      have hspan :=
        ih hS_tail
      have hface : faceBoundary f ∈ faceOrderBoundarySet faceBoundary faceOrder :=
        (mem_faceOrderBoundarySet_iff faceBoundary faceOrder).2
          ⟨f, hS f (Finset.mem_insert_self f S), rfl⟩
      have hspan_add :=
        faceBoundarySpan_add_face
          (γ := γ) (faces := faceOrderBoundarySet faceBoundary faceOrder)
          (x := ∑ g ∈ S, faceBoundaryChain γ (faceBoundary g)) hspan hface
      simpa [Finset.sum_insert hnot, add_comm, add_left_comm, add_assoc] using hspan_add

/-- The set of color-chain generators obtained from the faces listed by an
ordered peel. -/
def faceOrderBoundaryGeneratorSet
    [DecidableEq E] (γ : Color) (faceBoundary : F → Finset E)
    (faceOrder : List F) : Set (E → Color) :=
  {x | ∃ f ∈ faceOrder, x = faceBoundaryChain γ (faceBoundary f)}

theorem mem_faceOrderBoundaryGeneratorSet_iff
    [DecidableEq E] (γ : Color) (faceBoundary : F → Finset E)
    (faceOrder : List F) {x : E → Color} :
    x ∈ faceOrderBoundaryGeneratorSet γ faceBoundary faceOrder ↔
      ∃ f ∈ faceOrder, x = faceBoundaryChain γ (faceBoundary f) :=
  Iff.rfl

/-- The listed-face generator set is the same as the generator set obtained
from the image face-boundary set. This removes a later source of duplicate
generator vocabularies. -/
theorem faceOrderBoundaryGeneratorSet_eq_imageGeneratorSet
    [DecidableEq E] (γ : Color) (faceBoundary : F → Finset E)
    (faceOrder : List F) :
    faceOrderBoundaryGeneratorSet γ faceBoundary faceOrder =
      faceBoundaryGeneratorSet γ (faceOrderBoundarySet faceBoundary faceOrder) := by
  ext x
  constructor
  · intro hx
    rcases hx with ⟨f, hf, rfl⟩
    exact ⟨faceBoundary f,
      (mem_faceOrderBoundarySet_iff faceBoundary faceOrder).2 ⟨f, hf, rfl⟩,
      rfl⟩
  · intro hx
    rcases hx with ⟨B, hB, hxB⟩
    rcases (mem_faceOrderBoundarySet_iff faceBoundary faceOrder).1 hB with
      ⟨f, hf, hfB⟩
    exact ⟨f, hf, by simpa [hfB] using hxB⟩

/-- Orthogonality to every listed face-boundary generator propagates to the
whole finite span generated by an ordered peel. -/
theorem faceOrderBoundarySpan_orthogonal_on_of_generators
    [DecidableEq E] {support : Finset E} {γ : Color}
    (faceBoundary : F → Finset E) {faceOrder : List F} {y : E → Color}
    (h : ∀ f ∈ faceOrder,
      IsOrthogonalOn support (faceBoundaryChain γ (faceBoundary f)) y) :
    ∀ x ∈ faceBoundarySpan γ (faceOrderBoundarySet faceBoundary faceOrder),
      IsOrthogonalOn support x y := by
  exact faceBoundarySpan_orthogonal_on_of_generators
    (S := support) (γ := γ)
    (faces := faceOrderBoundarySet faceBoundary faceOrder)
    (y := y)
    (by
      intro B hB
      rcases (mem_faceOrderBoundarySet_iff faceBoundary faceOrder).1 hB with
        ⟨f, hf, rfl⟩
      exact h f hf)

/-- The span generated by an ordered peel is contained in the finite-support
double orthogonal of its listed face-boundary generators. -/
theorem faceOrderBoundarySpan_subset_doubleOrthogonalOn
    [DecidableEq E] (support : Finset E) {γ : Color}
    (faceBoundary : F → Finset E) (faceOrder : List F) :
    faceBoundarySpan γ (faceOrderBoundarySet faceBoundary faceOrder) ⊆
      DoubleOrthogonalOn support
        (faceOrderBoundaryGeneratorSet γ faceBoundary faceOrder) := by
  rw [faceOrderBoundaryGeneratorSet_eq_imageGeneratorSet]
  exact faceBoundarySpan_subset_doubleOrthogonalOn support
    (faceOrderBoundarySet faceBoundary faceOrder)

/-- If a chain annihilates every listed face-boundary generator, then every
chain in the ordered-peel span is orthogonal to it. -/
theorem faceOrderBoundarySpan_orthogonal_on_of_mem_annihilator
    [DecidableEq E] (support : Finset E) {γ : Color}
    (faceBoundary : F → Finset E) (faceOrder : List F) {y : E → Color}
    (hy : y ∈
      AnnihilatorOn support (faceOrderBoundaryGeneratorSet γ faceBoundary faceOrder)) :
    ∀ x ∈ faceBoundarySpan γ (faceOrderBoundarySet faceBoundary faceOrder),
      IsOrthogonalOn support x y := by
  rw [faceOrderBoundaryGeneratorSet_eq_imageGeneratorSet] at hy
  exact faceBoundarySpan_orthogonal_on_of_mem_annihilator support hy

namespace BoundaryRootedFacePeelCertificate

variable [DecidableEq F]
variable {G : SimpleGraph V}
variable {allFaces : Finset F} {faceBoundary : F → Finset G.edgeSet}

/-- The finite face-boundary set generated by the ordered faces in a
boundary-rooted peel certificate. -/
noncomputable def faceBoundarySet
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary) :
    Finset (Finset G.edgeSet) :=
  faceOrderBoundarySet faceBoundary cert.faceOrder

theorem mem_faceBoundarySet_iff
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    {B : Finset G.edgeSet} :
    B ∈ cert.faceBoundarySet ↔
      ∃ f ∈ cert.faceOrder, faceBoundary f = B := by
  classical
  simpa [faceBoundarySet] using
    mem_faceOrderBoundarySet_iff faceBoundary cert.faceOrder (B := B)

/-- A face in the certificate order has its boundary chain in the span generated
by the certificate's ordered face-boundary set. -/
theorem faceBoundaryChain_mem_faceBoundarySpan
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    {γ : Color} {f : F} (hf : f ∈ cert.faceOrder) :
    faceBoundaryChain γ (faceBoundary f) ∈
      faceBoundarySpan γ cert.faceBoundarySet := by
  classical
  simpa [faceBoundarySet] using
    faceBoundaryChain_mem_faceBoundarySpan_of_mem_faceOrder
      (faceBoundary := faceBoundary) (γ := γ) hf

/-- The finite sum of boundary chains over any finite set of faces listed by
the certificate lies in the certificate-generated face-boundary span. -/
theorem faceBoundarySum_mem_faceBoundarySpan
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    {γ : Color} {S : Finset F} (hS : ∀ f ∈ S, f ∈ cert.faceOrder) :
    (∑ f ∈ S, faceBoundaryChain γ (faceBoundary f)) ∈
      faceBoundarySpan γ cert.faceBoundarySet := by
  classical
  simpa [faceBoundarySet] using
    faceBoundarySum_mem_faceBoundarySpan_of_subset_faceOrder
      (faceBoundary := faceBoundary) (γ := γ) hS

/-- The set of color-chain generators obtained from the faces listed by a
boundary-rooted peel certificate. -/
def faceBoundaryGeneratorSet
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    (γ : Color) : Set (G.edgeSet → Color) :=
  faceOrderBoundaryGeneratorSet γ faceBoundary cert.faceOrder

theorem mem_faceBoundaryGeneratorSet_iff
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    (γ : Color) {x : G.edgeSet → Color} :
    x ∈ cert.faceBoundaryGeneratorSet γ ↔
      ∃ f ∈ cert.faceOrder, x = faceBoundaryChain γ (faceBoundary f) :=
  Iff.rfl

/-- The certificate generator set agrees with the generic generator set
obtained from its finite `faceBoundarySet`. -/
theorem faceBoundaryGeneratorSet_eq_faceBoundarySetGeneratorSet
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    (γ : Color) :
    cert.faceBoundaryGeneratorSet γ =
      Mettapedia.GraphTheory.FourColor.faceBoundaryGeneratorSet γ cert.faceBoundarySet := by
  simpa [faceBoundaryGeneratorSet, faceBoundarySet] using
    faceOrderBoundaryGeneratorSet_eq_imageGeneratorSet
      (γ := γ) (faceBoundary := faceBoundary) (faceOrder := cert.faceOrder)

/-- Orthogonality to every face-boundary generator listed by a certificate
propagates to the certificate-generated face-boundary span. -/
theorem faceBoundarySpan_orthogonal_on_of_generators
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    {support : Finset G.edgeSet} {γ : Color} {y : G.edgeSet → Color}
    (h : ∀ f ∈ cert.faceOrder,
      IsOrthogonalOn support (faceBoundaryChain γ (faceBoundary f)) y) :
    ∀ x ∈ faceBoundarySpan γ cert.faceBoundarySet,
      IsOrthogonalOn support x y := by
  simpa [faceBoundarySet] using
    faceOrderBoundarySpan_orthogonal_on_of_generators
      (faceBoundary := faceBoundary) (γ := γ) (support := support) h

/-- The certificate-generated face-boundary span is contained in the
finite-support double orthogonal of the certificate's listed face-boundary
generators. -/
theorem faceBoundarySpan_subset_doubleOrthogonalOn
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    (support : Finset G.edgeSet) {γ : Color} :
    faceBoundarySpan γ cert.faceBoundarySet ⊆
      DoubleOrthogonalOn support (cert.faceBoundaryGeneratorSet γ) := by
  simpa [faceBoundarySet, faceBoundaryGeneratorSet] using
    faceOrderBoundarySpan_subset_doubleOrthogonalOn
      (support := support) (faceBoundary := faceBoundary)
      (faceOrder := cert.faceOrder) (γ := γ)

/-- If a chain annihilates the certificate's listed face-boundary generators,
then every chain in the certificate-generated span is orthogonal to it. -/
theorem faceBoundarySpan_orthogonal_on_of_mem_annihilator
    (cert : BoundaryRootedFacePeelCertificate allFaces faceBoundary)
    {support : Finset G.edgeSet} {γ : Color} {y : G.edgeSet → Color}
    (hy : y ∈ AnnihilatorOn support (cert.faceBoundaryGeneratorSet γ)) :
    ∀ x ∈ faceBoundarySpan γ cert.faceBoundarySet,
      IsOrthogonalOn support x y := by
  rw [faceBoundaryGeneratorSet_eq_faceBoundarySetGeneratorSet] at hy
  exact Mettapedia.GraphTheory.FourColor.faceBoundarySpan_orthogonal_on_of_mem_annihilator
    support hy

end BoundaryRootedFacePeelCertificate

end Mettapedia.GraphTheory.FourColor
