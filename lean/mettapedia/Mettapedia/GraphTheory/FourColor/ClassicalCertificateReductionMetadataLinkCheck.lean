/-- The exact link checker for any individual four-entry catalogue block. -/
theorem classicalReductionMetadataLinkChunk_checker
    (chunk : Nat) (hupper : chunk < 159) :
    chunkBoolean chunk = true := by
  by_cases h0 : chunk < 16
  · exact classicalReductionMetadataLinkBlocks000To015_checker chunk (by omega) h0
  by_cases h1 : chunk < 32
  · exact classicalReductionMetadataLinkBlocks016To031_checker chunk (by omega) h1
  by_cases h2 : chunk < 48
  · exact classicalReductionMetadataLinkBlocks032To047_checker chunk (by omega) h2
  by_cases h3 : chunk < 64
  · exact classicalReductionMetadataLinkBlocks048To063_checker chunk (by omega) h3
  by_cases h4 : chunk < 80
  · exact classicalReductionMetadataLinkBlocks064To079_checker chunk (by omega) h4
  by_cases h5 : chunk < 96
  · exact classicalReductionMetadataLinkBlocks080To095_checker chunk (by omega) h5
  by_cases h6 : chunk < 112
  · exact classicalReductionMetadataLinkBlocks096To111_checker chunk (by omega) h6
  by_cases h7 : chunk < 128
  · exact classicalReductionMetadataLinkBlocks112To127_checker chunk (by omega) h7
  by_cases h8 : chunk < 144
  · exact classicalReductionMetadataLinkBlocks128To143_checker chunk (by omega) h8
  exact classicalReductionMetadataLinkBlocks144To158_checker chunk (by omega) hupper

/-- The exact link checker for any individual catalogue entry. -/
theorem classicalReductionMetadataLinkEntry_checker
    (index : Nat) (hindex : index < 633) :
    entryBoolean index = true := by
  have hchunk : index / chunkSize < 159 := by
    simp only [chunkSize] at hindex ⊢
    omega
  have hchunkValid := classicalReductionMetadataLinkChunk_checker
    (index / chunkSize) hchunk
  have hoffset : index % chunkSize < chunkSize :=
    Nat.mod_lt _ (by decide)
  have hvalid := (List.all_eq_true.1 hchunkValid)
    (index % chunkSize) (List.mem_range.2 hoffset)
  have hindexEq : index / chunkSize * chunkSize + index % chunkSize = index :=
    by simpa [Nat.mul_comm] using Nat.div_add_mod index chunkSize
  simp [hindexEq, hindex] at hvalid
  exact hvalid

/-- Every exported reduction record agrees exactly with its catalogue
configuration, independently checked hypermap, boundary, and contract. -/
theorem classicalReductionMetadataLink_checker :
    checker = true := by
  change (List.range 159).all chunkBoolean = true
  apply List.all_eq_true.2
  intro chunk hchunk
  have hupper : chunk < 159 := List.mem_range.1 hchunk
  exact classicalReductionMetadataLinkChunk_checker chunk hupper

