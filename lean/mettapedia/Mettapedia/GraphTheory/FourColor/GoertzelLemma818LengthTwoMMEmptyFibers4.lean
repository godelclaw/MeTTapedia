theorem mmFiber66ExtractAllLefts_eq_nil :
    lengthTwoFiberExtractLeftStateList mmWord mmFiber66Key allTauStates = [] := by
  rw [allTauStates_eq_chunks32]
  repeat rw [lengthTwoFiberExtractLeftStateList_append]
  decide

theorem mmFiber66RealFiberConnected :
    chainFiberConnected mmWord (chainFiberFrom mmWord (allChainStates mmWord) mmFiber66Key) = true := by
  exact mmEmptyFiberConnected_of_extract_nil mmFiber66ExtractAllLefts_eq_nil

