def tttLargeFiber44ParentOf (i : Nat) : Nat :=
  if 4912 <= i ∧ i < 4976 then
    tttLargeFiber44ParentOfLow0Offset (i - 4912)
  else if 4976 <= i ∧ i < 5040 then
    tttLargeFiber44ParentOfLow1Offset (i - 4976)
  else if 5040 <= i ∧ i < 5104 then
    tttLargeFiber44ParentOfLow2Offset (i - 5040)
  else if 5104 <= i ∧ i < 5168 then
    tttLargeFiber44ParentOfLow3Offset (i - 5104)
  else if 5456 <= i ∧ i < 5520 then
    tttLargeFiber44ParentOfHigh0Offset (i - 5456)
  else if 5520 <= i ∧ i < 5584 then
    tttLargeFiber44ParentOfHigh1Offset (i - 5520)
  else if 5584 <= i ∧ i < 5648 then
    tttLargeFiber44ParentOfHigh2Offset (i - 5584)
  else if 5648 <= i ∧ i < 5712 then
    tttLargeFiber44ParentOfHigh3Offset (i - 5648)
  else
    i
def tttLargeFiber44ParentIter : Nat -> Nat -> Nat
  | 0, i => i
  | n + 1, i => tttLargeFiber44ParentIter n (tttLargeFiber44ParentOf i)

def tttLargeFiber44ParentConvergesCheck (i : Nat) : Bool :=
  tttLargeFiber44ParentIter tttLargeFiber44MaxParentDepth
    (listGetD tttLargeFiber44Expected i 0) == tttLargeFiber44Root

