def tttLargeFiber60ParentOf (i : Nat) : Nat :=
  if 544 <= i ∧ i < 608 then
    tttLargeFiber60ParentOfLow0Offset (i - 544)
  else if 608 <= i ∧ i < 672 then
    tttLargeFiber60ParentOfLow1Offset (i - 608)
  else if 672 <= i ∧ i < 736 then
    tttLargeFiber60ParentOfLow2Offset (i - 672)
  else if 736 <= i ∧ i < 800 then
    tttLargeFiber60ParentOfLow3Offset (i - 736)
  else if 1088 <= i ∧ i < 1152 then
    tttLargeFiber60ParentOfHigh0Offset (i - 1088)
  else if 1152 <= i ∧ i < 1216 then
    tttLargeFiber60ParentOfHigh1Offset (i - 1152)
  else if 1216 <= i ∧ i < 1280 then
    tttLargeFiber60ParentOfHigh2Offset (i - 1216)
  else if 1280 <= i ∧ i < 1344 then
    tttLargeFiber60ParentOfHigh3Offset (i - 1280)
  else
    i
def tttLargeFiber60ParentIter : Nat -> Nat -> Nat
  | 0, i => i
  | n + 1, i => tttLargeFiber60ParentIter n (tttLargeFiber60ParentOf i)

def tttLargeFiber60ParentConvergesCheck (i : Nat) : Bool :=
