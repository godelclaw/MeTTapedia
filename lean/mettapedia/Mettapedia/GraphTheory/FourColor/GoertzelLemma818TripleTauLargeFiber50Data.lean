  if 5184 <= i ∧ i < 5248 then
    tttLargeFiber50ParentOfLow0Offset (i - 5184)
  else if 5248 <= i ∧ i < 5312 then
    tttLargeFiber50ParentOfLow1Offset (i - 5248)
  else if 5312 <= i ∧ i < 5376 then
    tttLargeFiber50ParentOfLow2Offset (i - 5312)
  else if 5376 <= i ∧ i < 5440 then
    tttLargeFiber50ParentOfLow3Offset (i - 5376)
  else if 5728 <= i ∧ i < 5792 then
    tttLargeFiber50ParentOfHigh0Offset (i - 5728)
  else if 5792 <= i ∧ i < 5856 then
    tttLargeFiber50ParentOfHigh1Offset (i - 5792)
  else if 5856 <= i ∧ i < 5920 then
    tttLargeFiber50ParentOfHigh2Offset (i - 5856)
  else if 5920 <= i ∧ i < 5984 then
    tttLargeFiber50ParentOfHigh3Offset (i - 5920)
  else
    i
def tttLargeFiber50ParentIter : Nat -> Nat -> Nat
  | 0, i => i
  | n + 1, i => tttLargeFiber50ParentIter n (tttLargeFiber50ParentOf i)

def tttLargeFiber50ParentConvergesCheck (i : Nat) : Bool :=
