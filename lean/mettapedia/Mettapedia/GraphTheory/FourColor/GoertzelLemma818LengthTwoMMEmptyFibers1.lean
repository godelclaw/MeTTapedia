theorem mmFiber15ExtractAllLefts_eq_nil :
    lengthTwoFiberExtractLeftStateList mmWord mmFiber15Key allTauStates = [] := by
  rw [allTauStates_eq_chunks32]
  repeat rw [lengthTwoFiberExtractLeftStateList_append]
  decide

theorem mmFiber15RealFiberConnected :
    chainFiberConnected mmWord (chainFiberFrom mmWord (allChainStates mmWord) mmFiber15Key) = true := by
  exact mmEmptyFiberConnected_of_extract_nil mmFiber15ExtractAllLefts_eq_nil

