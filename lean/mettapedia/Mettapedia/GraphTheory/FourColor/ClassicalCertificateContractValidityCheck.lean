private theorem blockBoolean_of_four_localBlockBooleans
    (metadataCatalogue :
      ClassicalCertificateReductionMetadataCatalogue.Certificate)
    (validityCatalogue : Catalogue)
    (chunkIndex : Nat)
    (metadataChunk : Array ClassicalCertificateReductionMetadata.Code)
    (validityChunk : Array ClassicalCertificateContractValidity.Certificate)
    (hmetadataChunk :
      metadataCatalogue.chunks[chunkIndex]? = some metadataChunk)
    (hvalidityChunk :
      validityCatalogue.chunks[chunkIndex]? = some validityChunk)
    (h0 : localBlockBoolean metadataChunk validityChunk 0 = true)
    (h1 : localBlockBoolean metadataChunk validityChunk 1 = true)
    (h2 : localBlockBoolean metadataChunk validityChunk 2 = true)
    (h3 : localBlockBoolean metadataChunk validityChunk 3 = true)
    (subblock : Nat) (hsubblock : subblock < 4) :
    blockBoolean metadataCatalogue validityCatalogue
      (chunkIndex * 4 + subblock) = true := by
  interval_cases subblock
  · exact blockBoolean_of_localBlockBoolean metadataCatalogue
      validityCatalogue chunkIndex metadataChunk validityChunk
        hmetadataChunk hvalidityChunk 0 (by decide) h0
  · exact blockBoolean_of_localBlockBoolean metadataCatalogue
      validityCatalogue chunkIndex metadataChunk validityChunk
        hmetadataChunk hvalidityChunk 1 (by decide) h1
  · exact blockBoolean_of_localBlockBoolean metadataCatalogue
      validityCatalogue chunkIndex metadataChunk validityChunk
        hmetadataChunk hvalidityChunk 2 (by decide) h2
  · exact blockBoolean_of_localBlockBoolean metadataCatalogue
      validityCatalogue chunkIndex metadataChunk validityChunk
        hmetadataChunk hvalidityChunk 3 (by decide) h3

private theorem classicalContractValidityBlocks000To015_checker
    (block : Nat) (hlower : 0 ≤ block)
    (hupper : block < 16) :
    blockBoolean classicalReductionMetadataCatalogue
      classicalContractValidityCatalogue block = true := by
  let chunkIndex := block / 4
  let subblock := block % 4
  have hsubblock : subblock < 4 :=
    Nat.mod_lt _ (by decide)
  have hdecomp : chunkIndex * 4 + subblock = block := by
    simpa [chunkIndex, subblock, Nat.mul_comm] using
      Nat.div_add_mod block 4
  rw [← hdecomp]
  have hchunkLower : 0 ≤ chunkIndex := by
    dsimp [chunkIndex]
    omega
  have hchunkUpper : chunkIndex < 4 := by
    dsimp [chunkIndex]
    omega
  interval_cases chunkIndex <;>
    first
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue
          classicalContractValidityCatalogue 0
            classicalReductionMetadataChunk00
              classicalContractValidityChunk00 (by rfl) (by rfl)
                classicalContractValidityBlock000_checker
                classicalContractValidityBlock001_checker
                classicalContractValidityBlock002_checker
                classicalContractValidityBlock003_checker
                subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue
          classicalContractValidityCatalogue 1
            classicalReductionMetadataChunk01
              classicalContractValidityChunk01 (by rfl) (by rfl)
                classicalContractValidityBlock004_checker
                classicalContractValidityBlock005_checker
                classicalContractValidityBlock006_checker
                classicalContractValidityBlock007_checker
                subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue
          classicalContractValidityCatalogue 2
            classicalReductionMetadataChunk02
              classicalContractValidityChunk02 (by rfl) (by rfl)
                classicalContractValidityBlock008_checker
                classicalContractValidityBlock009_checker
                classicalContractValidityBlock010_checker
                classicalContractValidityBlock011_checker
                subblock hsubblock
    | exact blockBoolean_of_four_localBlockBooleans
        classicalReductionMetadataCatalogue
          classicalContractValidityCatalogue 3
            classicalReductionMetadataChunk03
              classicalContractValidityChunk03 (by rfl) (by rfl)
                classicalContractValidityBlock012_checker
                classicalContractValidityBlock013_checker
                classicalContractValidityBlock014_checker
                classicalContractValidityBlock015_checker
                subblock hsubblock

