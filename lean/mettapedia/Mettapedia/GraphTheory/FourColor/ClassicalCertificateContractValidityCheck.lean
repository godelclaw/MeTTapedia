/-- Every classical catalogue contract satisfies the reflected standard
validity conditions. -/
theorem classicalContractValidity_checker :
    checker classicalReductionMetadataCatalogue
      classicalContractValidityCatalogue = true := by
  unfold checker blockCount
  rw [ClassicalCertificateReductionMetadataData.classicalReductionMetadataCatalogue_chunkCount,
    classicalContractValidityCatalogue_chunkCount]
  norm_num [blocksPerChunk, chunkSize, blockSize]
  intro block hblock
  by_cases h0 : block < 16
  · exact classicalContractValidityBlocks000To015_checker
      block (by omega) h0
  by_cases h1 : block < 32
  · exact classicalContractValidityBlocks016To031_checker
      block (by omega) h1
  by_cases h2 : block < 48
  · exact classicalContractValidityBlocks032To047_checker
      block (by omega) h2
  by_cases h3 : block < 64
  · exact classicalContractValidityBlocks048To063_checker
      block (by omega) h3
  by_cases h4 : block < 80
  · exact classicalContractValidityBlocks064To079_checker
      block (by omega) h4
  by_cases h5 : block < 96
  · exact classicalContractValidityBlocks080To095_checker
      block (by omega) h5
  by_cases h6 : block < 112
  · exact classicalContractValidityBlocks096To111_checker
      block (by omega) h6
  by_cases h7 : block < 128
  · exact classicalContractValidityBlocks112To127_checker
      block (by omega) h7
  by_cases h8 : block < 144
  · exact classicalContractValidityBlocks128To143_checker
      block (by omega) h8
  exact classicalContractValidityBlocks144To159_checker block (by omega) hblock

