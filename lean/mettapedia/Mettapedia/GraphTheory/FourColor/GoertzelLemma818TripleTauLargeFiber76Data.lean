    tttLargeFiber76ParentOfLow0Offset (i - 2992)
  else if 3056 <= i ∧ i < 3120 then
    tttLargeFiber76ParentOfLow1Offset (i - 3056)
  else if 3120 <= i ∧ i < 3184 then
    tttLargeFiber76ParentOfLow2Offset (i - 3120)
  else if 3184 <= i ∧ i < 3248 then
    tttLargeFiber76ParentOfLow3Offset (i - 3184)
  else if 3552 <= i ∧ i < 3616 then
    tttLargeFiber76ParentOfHigh0Offset (i - 3552)
  else if 3616 <= i ∧ i < 3680 then
    tttLargeFiber76ParentOfHigh1Offset (i - 3616)
