import Mettapedia.QuantumTheory.YangMills.HypercubicDimension16PhysicalInvariantSpace

/-!
# Signed orbit coinvariants in the eight-field sector

The signed hypercubic coinvariant quotient of the genuine field-label orbit
module is identified with the Reynolds-invariant subspace.  The relation
submodule is generated by the literal rows `v - h • v`; no coordinate chart
or enumerated orbit representative is used in its definition.
-/

set_option autoImplicit false
set_option maxRecDepth 100000
set_option maxHeartbeats 0
noncomputable section

namespace Mettapedia
namespace QuantumTheory
namespace YangMills
namespace HypercubicDimension16SignedOrbitCoinvariants

open V14HypercubicFDCensus
open HypercubicDimension16LocalWordCarrier
open HypercubicDimension16PhysicalInvariantSpace

abbrev FieldEightOrbitCarrier := FieldRelabelOrbitCarrier 8 0

abbrev FieldEightOrbitSpace := SectorFieldOrbitSpace 8 0

/-- One literal signed-orbit identification row. -/
def fieldEightSignedOrbitRow
    (h : Hypercubic4) (target : FieldEightOrbitCarrier) :
    FieldEightOrbitSpace :=
  Finsupp.single target 1 -
    signedSectorFieldOrbitAction h 8 0 (Finsupp.single target 1)

/-- The standard signed coinvariant relation submodule. -/
def fieldEightSignedOrbitRelationSubmodule :
    Submodule ℚ FieldEightOrbitSpace :=
  Submodule.span ℚ
    (Set.range fun site : Hypercubic4 × FieldEightOrbitCarrier =>
      fieldEightSignedOrbitRow site.1 site.2)

theorem sectorFieldOrbitReynolds_action
    (right : Hypercubic4) (value : FieldEightOrbitSpace) :
    sectorFieldOrbitReynolds 8 0
        (signedSectorFieldOrbitAction right 8 0 value) =
      sectorFieldOrbitReynolds 8 0 value := by
  have hsum :
      (∑ left : Hypercubic4,
          signedSectorFieldOrbitAction left 8 0) *
          signedSectorFieldOrbitAction right 8 0 =
        ∑ left : Hypercubic4,
          signedSectorFieldOrbitAction left 8 0 := by
    rw [Finset.sum_mul]
    have hmul (left : Hypercubic4) :
        signedSectorFieldOrbitAction left 8 0 *
            signedSectorFieldOrbitAction right 8 0 =
          signedSectorFieldOrbitAction (left * right) 8 0 := by
      apply LinearMap.ext
      intro input
      exact (signedSectorFieldOrbitAction_mul left right input).symm
    simp_rw [hmul]
    exact Equiv.sum_comp (Equiv.mulRight right)
      (signedSectorFieldOrbitRepresentation 8 0)
  unfold sectorFieldOrbitReynolds
  change
    (((1 / 384 : ℚ) •
        ∑ left : Hypercubic4,
          signedSectorFieldOrbitAction left 8 0) *
        signedSectorFieldOrbitAction right 8 0) value =
      ((1 / 384 : ℚ) •
        ∑ left : Hypercubic4,
          signedSectorFieldOrbitAction left 8 0) value
  rw [smul_mul_assoc, hsum]

theorem fieldEightSignedOrbitRow_mem_kernel
    (h : Hypercubic4) (target : FieldEightOrbitCarrier) :
    fieldEightSignedOrbitRow h target ∈
      LinearMap.ker (sectorFieldOrbitReynolds 8 0) := by
  rw [LinearMap.mem_ker]
  simp only [fieldEightSignedOrbitRow, LinearMap.map_sub]
  rw [sectorFieldOrbitReynolds_action]
  exact sub_self _

theorem fieldEightSignedOrbitRelationSubmodule_le_kernel :
    fieldEightSignedOrbitRelationSubmodule ≤
      LinearMap.ker (sectorFieldOrbitReynolds 8 0) := by
  unfold fieldEightSignedOrbitRelationSubmodule
  rw [Submodule.span_le]
  rintro _ ⟨⟨h, target⟩, rfl⟩
  exact fieldEightSignedOrbitRow_mem_kernel h target

theorem single_sub_reynolds_mem_signedOrbitRelations
    (target : FieldEightOrbitCarrier) :
    Finsupp.single target 1 -
        sectorFieldOrbitReynolds 8 0 (Finsupp.single target 1) ∈
      fieldEightSignedOrbitRelationSubmodule := by
  have hsum :
      (∑ h : Hypercubic4, fieldEightSignedOrbitRow h target) ∈
        fieldEightSignedOrbitRelationSubmodule := by
    apply Submodule.sum_mem
    intro h _
    exact Submodule.subset_span ⟨(h, target), rfl⟩
  have hscaled := fieldEightSignedOrbitRelationSubmodule.smul_mem
    (1 / 384 : ℚ) hsum
  have hequality :
      Finsupp.single target 1 -
          sectorFieldOrbitReynolds 8 0 (Finsupp.single target 1) =
        (1 / 384 : ℚ) •
          ∑ h : Hypercubic4, fieldEightSignedOrbitRow h target := by
    unfold sectorFieldOrbitReynolds fieldEightSignedOrbitRow
    change Finsupp.single target 1 -
        (1 / 384 : ℚ) •
          (∑ h : Hypercubic4,
            signedSectorFieldOrbitAction h 8 0
              (Finsupp.single target 1)) =
      (1 / 384 : ℚ) •
        ∑ h : Hypercubic4,
          (Finsupp.single target 1 -
            signedSectorFieldOrbitAction h 8 0
              (Finsupp.single target 1))
    rw [Finset.sum_sub_distrib, Finset.sum_const,
      Finset.card_univ, Hypercubic4.card_hypercubic4]
    module
  rw [hequality]
  exact hscaled

theorem value_sub_reynolds_mem_signedOrbitRelations
    (value : FieldEightOrbitSpace) :
    value - sectorFieldOrbitReynolds 8 0 value ∈
      fieldEightSignedOrbitRelationSubmodule := by
  induction value using Finsupp.induction_linear with
  | zero => simp
  | add left right hleft hright =>
      have hadd := fieldEightSignedOrbitRelationSubmodule.add_mem hleft hright
      rw [LinearMap.map_add]
      have hequality :
          left + right -
              (sectorFieldOrbitReynolds 8 0 left +
                sectorFieldOrbitReynolds 8 0 right) =
            (left - sectorFieldOrbitReynolds 8 0 left) +
              (right - sectorFieldOrbitReynolds 8 0 right) := by
        module
      rw [hequality]
      exact hadd
  | single target coefficient =>
      have hbase := single_sub_reynolds_mem_signedOrbitRelations target
      have hscaled := fieldEightSignedOrbitRelationSubmodule.smul_mem
        coefficient hbase
      have hsingle :
          Finsupp.single target coefficient =
            coefficient • Finsupp.single target (1 : ℚ) := by
        simp
      rw [hsingle, LinearMap.map_smul, ← smul_sub]
      exact hscaled

theorem ker_sectorFieldOrbitReynolds_eq_signedOrbitRelations :
    LinearMap.ker (sectorFieldOrbitReynolds 8 0) =
      fieldEightSignedOrbitRelationSubmodule := by
  apply le_antisymm
  · intro value membership
    have hresidual := value_sub_reynolds_mem_signedOrbitRelations value
    have hzero := LinearMap.mem_ker.mp membership
    rw [hzero, sub_zero] at hresidual
    exact hresidual
  · exact fieldEightSignedOrbitRelationSubmodule_le_kernel

/-- Reynolds projection with codomain restricted to the invariant subspace. -/
def fieldEightReynoldsToInvariant :
    FieldEightOrbitSpace →ₗ[ℚ]
      sectorFieldOrbitInvariantSubmodule 8 0 :=
  (sectorFieldOrbitReynolds 8 0).codRestrict
    (sectorFieldOrbitInvariantSubmodule 8 0)
    (sectorFieldOrbitReynolds_invariant 8 0)

theorem fieldEightReynoldsToInvariant_surjective :
    Function.Surjective fieldEightReynoldsToInvariant := by
  intro value
  refine ⟨value.1, Subtype.ext ?_⟩
  exact sectorFieldOrbitReynolds_fixes_invariant 8 0 value.1 value.2

theorem ker_fieldEightReynoldsToInvariant :
    LinearMap.ker fieldEightReynoldsToInvariant =
      fieldEightSignedOrbitRelationSubmodule := by
  rw [fieldEightReynoldsToInvariant, LinearMap.ker_codRestrict,
    ker_sectorFieldOrbitReynolds_eq_signedOrbitRelations]

abbrev FieldEightSignedOrbitCoinvariant :=
  FieldEightOrbitSpace ⧸ fieldEightSignedOrbitRelationSubmodule

/-- In characteristic zero, signed coinvariants and signed invariants agree. -/
def fieldEightSignedOrbitCoinvariantEquivInvariant :
    FieldEightSignedOrbitCoinvariant ≃ₗ[ℚ]
      sectorFieldOrbitInvariantSubmodule 8 0 :=
  (Submodule.quotEquivOfEq fieldEightSignedOrbitRelationSubmodule
      (LinearMap.ker fieldEightReynoldsToInvariant)
      ker_fieldEightReynoldsToInvariant.symm).trans
    (fieldEightReynoldsToInvariant.quotKerEquivOfSurjective
      fieldEightReynoldsToInvariant_surjective)

/-- The honest signed-orbit coinvariant target has exactly 11,654 dimensions. -/
theorem fieldEightSignedOrbitCoinvariant_finrank :
    Module.finrank ℚ FieldEightSignedOrbitCoinvariant = 11654 := by
  have hfinrank :=
    LinearEquiv.finrank_eq fieldEightSignedOrbitCoinvariantEquivInvariant
  rw [fieldEightScalarInvariantDimension] at hfinrank
  exact hfinrank

end HypercubicDimension16SignedOrbitCoinvariants
end YangMills
end QuantumTheory
end Mettapedia
