open SU2CanonicalTruncationObstruction

/-! ## An infinite exact `SU(2)` test family -/

def cayleyCos (t : ℝ) : ℝ := (1 - t ^ 2) / (1 + t ^ 2)

def cayleySin (t : ℝ) : ℝ := (2 * t) / (1 + t ^ 2)

theorem cayley_denominator_pos (t : ℝ) : 0 < 1 + t ^ 2 := by positivity

theorem cayley_cos_sq_add_sin_sq (t : ℝ) :
    cayleyCos t ^ 2 + cayleySin t ^ 2 = 1 := by
  have hne : 1 + t ^ 2 ≠ 0 := (cayley_denominator_pos t).ne'
  unfold cayleyCos cayleySin
  field_simp [hne]
  ring

/-- Real Cayley rotation, regarded as a two-by-two complex matrix. -/
def cayleyRotationMatrix (t : ℝ) : Matrix (Fin 2) (Fin 2) ℂ :=
  !![(cayleyCos t : ℂ), (cayleySin t : ℂ);
     (-(cayleySin t) : ℂ), (cayleyCos t : ℂ)]

/-- Every real Cayley rotation is an actual element of `SU(2)`. -/
def cayleyRotation (t : ℝ) : SU2 :=
  ⟨cayleyRotationMatrix t, by
    have hc :
        (cayleyCos t : ℂ) ^ 2 + (cayleySin t : ℂ) ^ 2 = 1 := by
      exact_mod_cast cayley_cos_sq_add_sin_sq t
    rw [Matrix.mem_specialUnitaryGroup_iff]
    constructor
    · rw [Matrix.mem_unitaryGroup_iff]
      ext i j
      fin_cases i <;> fin_cases j
      · simpa [cayleyRotationMatrix, Matrix.mul_apply, pow_two] using hc
      · simp [cayleyRotationMatrix, Matrix.mul_apply]
        ring
      · simp [cayleyRotationMatrix, Matrix.mul_apply]
        ring
      · simpa [cayleyRotationMatrix, Matrix.mul_apply, pow_two,
          add_comm] using hc
    · simpa [cayleyRotationMatrix, Matrix.det_fin_two, pow_two]
        using hc⟩

theorem centeredTrace_cayleyRotation (t : ℝ) :
    centeredTrace (cayleyRotation t) =
      ((4 * t ^ 2 / (1 + t ^ 2) : ℝ) : ℂ) := by
  have hne : 1 + t ^ 2 ≠ 0 := (cayley_denominator_pos t).ne'
  have hreal :
      2 - (cayleyCos t + cayleyCos t) =
        4 * t ^ 2 / (1 + t ^ 2) := by
    unfold cayleyCos
    field_simp [hne]
    ring
  simpa [centeredTrace, cayleyRotation, cayleyRotationMatrix,
    Matrix.trace, Fin.sum_univ_two] using congrArg Complex.ofReal hreal

/-- Centered-trace values on natural Cayley parameters. -/
def cayleyTraceParameter (n : ℕ) : ℂ :=
  centeredTrace (cayleyRotation n)

theorem cayleyTraceParameter_injective :
    Function.Injective cayleyTraceParameter := by
  intro m n h
  have hreal :
      (4 * (m : ℝ) ^ 2 / (1 + (m : ℝ) ^ 2)) =
        4 * (n : ℝ) ^ 2 / (1 + (n : ℝ) ^ 2) := by
    apply Complex.ofReal_injective
    simpa [cayleyTraceParameter, centeredTrace_cayleyRotation] using h
  have hmpos : (0 : ℝ) < 1 + (m : ℝ) ^ 2 := by positivity
  have hnpos : (0 : ℝ) < 1 + (n : ℝ) ^ 2 := by positivity
  have hsquares : (m : ℝ) ^ 2 = (n : ℝ) ^ 2 := by
    field_simp [hmpos.ne', hnpos.ne'] at hreal
    nlinarith
  have hcasts : (m : ℝ) = (n : ℝ) := by
    have hm0 : (0 : ℝ) ≤ m := by positivity
    have hn0 : (0 : ℝ) ≤ n := by positivity
    nlinarith
  exact_mod_cast hcasts

/-! ## Exact normal form of every generated trace word -/

/-- Variables `0` and `1` represent `a = 2-tr(U)` and
`b = 2-tr(U²)`, respectively. -/
abbrev CenteredTracePolynomial := MvPolynomial (Fin 2) ℂ

def centeredTraceAssignment (U : SU2) : Fin 2 → ℂ
  | 0 => centeredTrace U
  | 1 => centeredDoubleTrace U

def evaluateCenteredTracePolynomial
    (p : CenteredTracePolynomial) (U : SU2) : ℂ :=
  MvPolynomial.eval (centeredTraceAssignment U) p

/-- Exact Cayley--Hamilton normal form: substitute `a` for variable zero and
`4a-a²` for variable one. -/
def centeredTraceNormalForm :
    CenteredTracePolynomial →+* Polynomial ℂ :=
  MvPolynomial.eval₂Hom Polynomial.C fun i =>
    if i = 0 then Polynomial.X else 4 * Polynomial.X - Polynomial.X ^ 2

theorem centeredTraceNormalForm_X_zero :
    centeredTraceNormalForm (MvPolynomial.X 0) = Polynomial.X := by
  simp [centeredTraceNormalForm]

theorem centeredTraceNormalForm_X_one :
    centeredTraceNormalForm (MvPolynomial.X 1) =
      4 * Polynomial.X - Polynomial.X ^ 2 := by
  simp [centeredTraceNormalForm]

/-- Normalization preserves evaluation on every actual `SU(2)` matrix. -/
theorem centeredTraceNormalForm_eval
    (p : CenteredTracePolynomial) (U : SU2) :
    Polynomial.eval (centeredTrace U) (centeredTraceNormalForm p) =
      evaluateCenteredTracePolynomial p U := by
  let lhs : CenteredTracePolynomial →+* ℂ :=
    (Polynomial.evalRingHom (centeredTrace U)).comp centeredTraceNormalForm
  let rhs : CenteredTracePolynomial →+* ℂ :=
    MvPolynomial.eval₂Hom (RingHom.id ℂ) (centeredTraceAssignment U)
  have hrings : lhs = rhs := by
    apply MvPolynomial.ringHom_ext
    · intro c
      simp [lhs, rhs, centeredTraceNormalForm]
    · intro i
      fin_cases i
      · simp [lhs, rhs, centeredTraceNormalForm,
          centeredTraceAssignment]
      · simp [lhs, rhs, centeredTraceNormalForm,
          centeredTraceAssignment, centeredDoubleTrace_eq]
  exact RingHom.congr_fun hrings p

/-- Semantic equality in the exact generated trace-word algebra. -/
def CenteredTraceSemanticallyEquivalent
    (p q : CenteredTracePolynomial) : Prop :=
  ∀ U : SU2,
    evaluateCenteredTracePolynomial p U =
      evaluateCenteredTracePolynomial q U

theorem centeredTrace_semantic_iff_normalForm
    (p q : CenteredTracePolynomial) :
    CenteredTraceSemanticallyEquivalent p q ↔
      centeredTraceNormalForm p = centeredTraceNormalForm q := by
  constructor
  · intro h
    apply Polynomial.eq_of_infinite_eval_eq
    refine (Set.infinite_range_of_injective cayleyTraceParameter_injective).mono ?_
    rintro x ⟨n, rfl⟩
    simpa [cayleyTraceParameter,
      centeredTraceNormalForm_eval] using h (cayleyRotation n)
  · intro h U
    rw [← centeredTraceNormalForm_eval p U,
      ← centeredTraceNormalForm_eval q U, h]

/-! ## Equivalence with evaluation on the exact block -/

/-- An actual block field whose selected profile plaquette has prescribed
holonomy `W`. -/
def holonomyRealizingBlockField (W : SU2) : BlockLinkField :=
  fun e => if e = (profilePlaquette 1).firstLink then W else 1

theorem holonomyRealizingBlockField_holonomy (W : SU2) :
    plaquetteHolonomy (holonomyRealizingBlockField W)
      (profilePlaquette 1) = W := by
  have hsf : (profilePlaquette 1).secondAfterFirst ≠
      (profilePlaquette 1).firstLink := by decide
  have hfs : (profilePlaquette 1).firstAfterSecond ≠
      (profilePlaquette 1).firstLink := by decide
  have hss : (profilePlaquette 1).secondLink ≠
      (profilePlaquette 1).firstLink := by decide
  simp [plaquetteHolonomy, holonomyRealizingBlockField, hsf, hfs, hss]

/-- Semantic equality evaluated on every actual block field and plaquette. -/
def CenteredTraceBlockSemanticallyEquivalent
    (p q : CenteredTracePolynomial) : Prop :=
  ∀ (U : BlockLinkField) (plaquette : BlockPlaquette),
    evaluateCenteredTracePolynomial p (plaquetteHolonomy U plaquette) =
      evaluateCenteredTracePolynomial q (plaquetteHolonomy U plaquette)

/-- The semantic quotient tested on abstract `SU(2)` holonomies is exactly
the semantic quotient tested on the actual `b = 2` block.  Surjectivity is
witnessed by `holonomyRealizingBlockField`. -/
theorem centeredTrace_blockSemantic_iff
    (p q : CenteredTracePolynomial) :
    CenteredTraceBlockSemanticallyEquivalent p q ↔
      CenteredTraceSemanticallyEquivalent p q := by
  constructor
  · intro h W
    simpa [holonomyRealizingBlockField_holonomy] using
      h (holonomyRealizingBlockField W) (profilePlaquette 1)
  · intro h U plaquette
    exact h (plaquetteHolonomy U plaquette)

instance centeredTraceSemanticSetoid : Setoid CenteredTracePolynomial where
  r := CenteredTraceSemanticallyEquivalent
  iseqv := ⟨
    fun _ _ => rfl,
    fun h U => (h U).symm,
    fun hpq hqr U => (hpq U).trans (hqr U)⟩

abbrev EvaluatedCenteredTraceQuotient :=
  Quotient centeredTraceSemanticSetoid

def centeredTraceQuotientClass
    (p : CenteredTracePolynomial) : EvaluatedCenteredTraceQuotient :=
  Quotient.mk centeredTraceSemanticSetoid p

/-- Embed a one-variable normal polynomial using only the fundamental
centered-trace variable. -/
def embedCenteredTraceNormal :
    Polynomial ℂ →+* CenteredTracePolynomial :=
  Polynomial.eval₂RingHom MvPolynomial.C (MvPolynomial.X 0)

theorem centeredTraceNormalForm_embed (p : Polynomial ℂ) :
    centeredTraceNormalForm (embedCenteredTraceNormal p) = p := by
  have hhom :
      centeredTraceNormalForm.comp embedCenteredTraceNormal =
        RingHom.id (Polynomial ℂ) := by
    apply Polynomial.ringHom_ext
    · intro c
      simp [embedCenteredTraceNormal, centeredTraceNormalForm]
    · simp [embedCenteredTraceNormal, centeredTraceNormalForm]
  exact RingHom.congr_fun hhom p

/-- Normal form of an evaluated quotient class; well-defined by the semantic
uniqueness theorem. -/
def evaluatedCenteredTraceNormalForm :
    EvaluatedCenteredTraceQuotient → Polynomial ℂ :=
  Quotient.lift centeredTraceNormalForm (by
    intro p q h
    exact (centeredTrace_semantic_iff_normalForm p q).mp h)

/-- The evaluated quotient is exactly the one-variable polynomial algebra. -/
def evaluatedCenteredTraceQuotientEquivPolynomial :
    EvaluatedCenteredTraceQuotient ≃ Polynomial ℂ where
  toFun := evaluatedCenteredTraceNormalForm
  invFun p := centeredTraceQuotientClass (embedCenteredTraceNormal p)
  left_inv := by
    intro q
    refine Quotient.inductionOn q ?_
    intro p
    apply Quotient.sound
    change CenteredTraceSemanticallyEquivalent
      (embedCenteredTraceNormal
        (evaluatedCenteredTraceNormalForm (centeredTraceQuotientClass p))) p
    rw [centeredTrace_semantic_iff_normalForm]
    exact centeredTraceNormalForm_embed _
  right_inv := centeredTraceNormalForm_embed

/-! ## The dimension-sixteen transversal and exact dual jets -/

/-- Independent normal-form basis elements `1,a,...,a⁴`. -/
def centeredTraceBasis16 (n : Fin 5) :
    EvaluatedCenteredTraceQuotient :=
  centeredTraceQuotientClass
    (embedCenteredTraceNormal (Polynomial.X ^ n.1))

/-- Exact coefficient dual on the quotient normal form. -/
def centeredTraceDualJet16 (n : Fin 5)
    (q : EvaluatedCenteredTraceQuotient) : ℂ :=
  (evaluatedCenteredTraceNormalForm q).coeff n.1

theorem evaluatedCenteredTraceNormalForm_basis16 (n : Fin 5) :
    evaluatedCenteredTraceNormalForm (centeredTraceBasis16 n) =
      Polynomial.X ^ n.1 := by
  exact centeredTraceNormalForm_embed _

theorem centeredTraceDualJet16_biorthogonal (m n : Fin 5) :
    centeredTraceDualJet16 m (centeredTraceBasis16 n) =
      if n = m then 1 else 0 := by
  classical
  rw [centeredTraceDualJet16,
    evaluatedCenteredTraceNormalForm_basis16]
  simp [Fin.ext_iff, eq_comm]

/-- Exact dual-jet matrix of the dimension-sixteen transversal. -/
def centeredTraceJetMatrix16 : Matrix (Fin 5) (Fin 5) ℂ :=
  fun m n => centeredTraceDualJet16 m (centeredTraceBasis16 n)

theorem centeredTraceJetMatrix16_eq_one : centeredTraceJetMatrix16 = 1 := by
  classical
  ext m n
  rw [centeredTraceJetMatrix16,
    centeredTraceDualJet16_biorthogonal]
  simp [Matrix.one_apply, eq_comm]

/-- Keep exactly normal-form powers `a⁰,...,a⁴`, corresponding to canonical
dimensions `0,4,8,12,16`. -/
def polynomialTruncateThroughFour (p : Polynomial ℂ) : Polynomial ℂ :=
  ∑ n ∈ Finset.range 5,
    Polynomial.C (p.coeff n) * Polynomial.X ^ n

theorem polynomialTruncateThroughFour_coeff
    (p : Polynomial ℂ) (n : ℕ) :
    (polynomialTruncateThroughFour p).coeff n =
      if n ≤ 4 then p.coeff n else 0 := by
  classical
  simp [polynomialTruncateThroughFour, Finset.mem_range,
    Nat.lt_succ_iff]

theorem polynomialTruncateThroughFour_eval
    (p : Polynomial ℂ) (a : ℂ) :
    (polynomialTruncateThroughFour p).eval a =
      ∑ n ∈ Finset.range 5, p.coeff n * a ^ n := by
  simp_rw [polynomialTruncateThroughFour,
    Polynomial.eval_finsetSum, Polynomial.eval_C_mul,
    Polynomial.eval_X_pow]

/-- Exact analytic realization of the independent-coordinate projection:
evaluation of the normal-form truncation at `a` is radial Taylor extraction
along the line `z ↦ z*a`.  Thus the norm theorem below is a bound on this
actual quotient extractor, not on an unrelated scalar operation. -/
theorem polynomialTruncateThroughFour_eval_eq_radialExtraction
    (p : Polynomial ℂ) (a : ℂ) :
    (polynomialTruncateThroughFour p).eval a =
      ∑ d ∈ Finset.range 5,
        radialJetCoefficient d (fun z : ℂ => p.eval (z * a)) := by
  rw [polynomialTruncateThroughFour_eval]
  apply Finset.sum_congr rfl
  intro d _
  rw [show (fun z : ℂ => p.eval (z * a)) =
      fun z : ℂ => (p.comp (Polynomial.C a * Polynomial.X)).eval z by
    funext z
    rw [Polynomial.eval_comp, Polynomial.eval_mul,
      Polynomial.eval_C, Polynomial.eval_X]
    rw [mul_comm a z]]
  rw [radialJetCoefficient_polynomial_eval,
    Polynomial.comp_C_mul_X_coeff]

/-- Independent-basis extraction on quotient classes.  Unlike the defeated
representative-wise truncation, this first takes the unique semantic normal
form and only then projects its independent coordinates. -/
def independentCenteredTraceExtraction16
    (q : EvaluatedCenteredTraceQuotient) :
    EvaluatedCenteredTraceQuotient :=
  centeredTraceQuotientClass
    (embedCenteredTraceNormal
      (polynomialTruncateThroughFour
        (evaluatedCenteredTraceNormalForm q)))

theorem independentCenteredTraceExtraction16_normalForm
    (q : EvaluatedCenteredTraceQuotient) :
    evaluatedCenteredTraceNormalForm
        (independentCenteredTraceExtraction16 q) =
      polynomialTruncateThroughFour
        (evaluatedCenteredTraceNormalForm q) := by
  exact centeredTraceNormalForm_embed _

/-- The exact manuscript-supremum-norm constant for the five retained radial
degrees at radius ratio `1/2`. -/
def independentTraceSupExtractionConstant16 : ℝ := (31 : ℝ) / 16

theorem independentTraceSupExtractionConstant16_lt_two :
    independentTraceSupExtractionConstant16 < 2 := by
  norm_num [independentTraceSupExtractionConstant16]

/-- Radial analytic norm bound for the independent trace basis.  The scalar
normal coordinate `a` has canonical dimension four, hence cutoff sixteen
retains radial degrees zero through four. -/
theorem norm_independentTraceRadialExtraction16_le
    {f : ℂ → ℂ} {C : ℝ}
    (hf : DiffContOnCl ℂ f (Metric.ball 0 2))
    (hbound : ∀ z ∈ Metric.sphere (0 : ℂ) 2, ‖f z‖ ≤ C) :
    ‖∑ d ∈ Finset.range 5, radialJetCoefficient d f‖ ≤
      independentTraceSupExtractionConstant16 * C := by
  calc
    ‖∑ d ∈ Finset.range 5, radialJetCoefficient d f‖
        ≤ ∑ d ∈ Finset.range 5, ‖radialJetCoefficient d f‖ :=
      norm_sum_le _ _
    _ ≤ ∑ d ∈ Finset.range 5, C * ((1 : ℝ) / 2) ^ d := by
      exact Finset.sum_le_sum fun d _ =>
        norm_radialJetCoefficient_le hf hbound d
    _ = independentTraceSupExtractionConstant16 * C := by
      norm_num [independentTraceSupExtractionConstant16,
        Finset.sum_range_succ]
      ring

/-- Uniform analytic bound for the actual quotient extractor on the exact
centered one-plaquette trace algebra.  The hypotheses are the literal radial
`H∞` obligations for the normal-form evaluation along `z ↦ z*a`. -/
theorem norm_independentCenteredTraceExtraction16_eval_le
    (q : EvaluatedCenteredTraceQuotient) (a : ℂ) {C : ℝ}
    (hf : DiffContOnCl ℂ
      (fun z : ℂ =>
        (evaluatedCenteredTraceNormalForm q).eval (z * a))
      (Metric.ball 0 2))
    (hbound : ∀ z ∈ Metric.sphere (0 : ℂ) 2,
      ‖(evaluatedCenteredTraceNormalForm q).eval (z * a)‖ ≤ C) :
    ‖(evaluatedCenteredTraceNormalForm
        (independentCenteredTraceExtraction16 q)).eval a‖ ≤
      independentTraceSupExtractionConstant16 * C := by
  rw [independentCenteredTraceExtraction16_normalForm,
    polynomialTruncateThroughFour_eval_eq_radialExtraction]
  exact norm_independentTraceRadialExtraction16_le hf hbound

