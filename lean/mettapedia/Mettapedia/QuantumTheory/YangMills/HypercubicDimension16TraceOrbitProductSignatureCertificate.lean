/-- Every adjacent pair in the sorted chart is strictly increasing. -/
theorem sortedProductSignature_lt_succ (index : Fin 11653) :
    sortedProductSignature index.castSucc <
      sortedProductSignature index.succ := by
  have h := sortedProductSignatureAt_lt_succ index
  unfold sortedProductSignatureAt at h
  calc
    sortedProductSignature index.castSucc =
        sortedProductSignature (Fin.ofNat 11654 index.1) := by
          apply congrArg sortedProductSignature
          apply Fin.ext
          change index.1 = index.1 % 11654
          rw [Nat.mod_eq_of_lt]
          omega
    _ < sortedProductSignature (Fin.ofNat 11654 (index.1 + 1)) := h
    _ = sortedProductSignature index.succ := by
          apply congrArg sortedProductSignature
          apply Fin.ext
          change (index.1 + 1) % 11654 = index.1 + 1
          rw [Nat.mod_eq_of_lt]
          omega

theorem sortedProductSignature_strictMono :
    StrictMono sortedProductSignature := by
  rw [Fin.strictMono_iff_lt_succ]
  exact sortedProductSignature_lt_succ

theorem expectedProductSignature_injective :
    Function.Injective expectedProductSignature := by
  intro left right hequal
  have hrank : productSignatureRank left =
      productSignatureRank right := by
    apply sortedProductSignature_strictMono.injective
    rw [sortedProductSignature_rank, sortedProductSignature_rank, hequal]
  calc
    left = representativeAtProductSignatureRank
        (productSignatureRank left) :=
      (representativeAtProductSignatureRank_rank left).symm
    _ = representativeAtProductSignatureRank
        (productSignatureRank right) := congrArg _ hrank
    _ = right := representativeAtProductSignatureRank_rank right

theorem directRepresentativeCanonicalProductSignature_injective :
    Function.Injective directRepresentativeCanonicalProductSignature := by
  intro left right hequal
  apply expectedProductSignature_injective
  rw [← representative_product_signature_replay left,
    ← representative_product_signature_replay right, hequal]

